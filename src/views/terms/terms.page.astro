---
import type { TermsTranslations } from "./terms.i18n";
import type { Language } from "@/lib/i18n";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";

import pattern04 from "@/assets/patterns/pattern-04.svg";
import pattern06 from "@/assets/patterns/pattern-06.svg";

interface Props {
  lang: Language;
  t: TermsTranslations;
}

const { lang, t } = Astro.props;
---

<PageHero title={t.title} subtitle={t.subtitle} />

<!-- Content -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern04.src} alt="" class="absolute top-8 right-4 md:-right-8 w-36 md:w-48 opacity-[0.09] rotate-[25deg] pointer-events-none select-none" />
  <img src={pattern06.src} alt="" class="absolute bottom-4 md:-bottom-16 left-4 md:-left-10 w-36 md:w-52 opacity-[0.09] -rotate-6 pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto prose prose-lg prose-olive" data-animate="fade">
      <!-- 1. Scope -->
      <h2>{t.scope.heading}</h2>
      <p>{t.scope.text}</p>

      <!-- 2. Tours -->
      <h2>{t.tours.heading}</h2>

      <h3>{t.tours.bookingTitle}</h3>
      <p>{t.tours.bookingText}</p>

      <h3>{t.tours.healthTitle}</h3>
      <p>{t.tours.healthDuty}</p>
      <p>{t.tours.healthLiability}</p>
      <p>{t.tours.healthNote}</p>

      <h3>{t.tours.cancellationTitle}</h3>
      <ul>
        <li>{t.tours.cancellation1}</li>
        <li>{t.tours.cancellation2}</li>
        <li>{t.tours.cancellation3}</li>
      </ul>

      <!-- 3. Accommodation -->
      <h2>{t.accommodation.heading}</h2>

      <h3>{t.accommodation.reservationTitle}</h3>
      <p>{t.accommodation.reservationText}</p>

      <h3>{t.accommodation.checkinTitle}</h3>
      <p>{t.accommodation.checkinText}</p>

      <h3>{t.accommodation.cancellationTitle}</h3>
      <ul>
        <li>{t.accommodation.cancellation1}</li>
        <li>{t.accommodation.cancellation2}</li>
        <li>{t.accommodation.cancellation3}</li>
        <li>{t.accommodation.cancellation4}</li>
      </ul>

      <h3>{t.accommodation.thirdPartyTitle}</h3>
      <p>{t.accommodation.thirdPartyText}</p>

      <!-- 4. General Provisions -->
      <h2>{t.finca.heading}</h2>

      <h3>{t.finca.safetyTitle}</h3>
      <p>{t.finca.safetyText}</p>

      <h3>{t.finca.liabilityTitle}</h3>
      <p>{t.finca.liabilityText}</p>

      <h3>{t.finca.rulesTitle}</h3>
      <ul>
        <li>{t.finca.rule1}</li>
        <li>{t.finca.rule2}</li>
        <li>{t.finca.rule3}</li>
      </ul>

      <h3>{t.finca.imageTitle}</h3>
      <p>{t.finca.imageText}</p>

      <h3>{t.finca.finalTitle}</h3>
      <p>{t.finca.finalText}</p>

      <!-- Source -->
      <p class="text-sm text-text-muted mt-12">{t.source}</p>
    </div>
  </Container>
</section>
