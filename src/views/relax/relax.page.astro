---
import type { RelaxTranslations } from "./relax.i18n";
import type { Language } from "@/lib/i18n";
import { Image } from "astro:assets";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";
import SubNav from "@/components/ui/SubNav.astro";
import { Icon } from "astro-icon/components";
import { getTranslatedPath } from "@/lib/registry";
import { siteData } from "@/data/site";

import pattern02 from "@/assets/patterns/pattern-02.svg";
import pattern04 from "@/assets/patterns/pattern-04.svg";
import pattern06 from "@/assets/patterns/pattern-06.svg";
import pattern07 from "@/assets/patterns/pattern-07.svg";

import introImg from "@/assets/relax/intro.jpg";
import natureImg from "@/assets/relax/nature.jpg";

import casaLiving from "@/assets/relax/casa/01-living.jpg";
import casaBedroom from "@/assets/relax/casa/02-bedroom.jpg";
import casaKitchen from "@/assets/relax/casa/03-kitchen.jpg";
import casaBathroom from "@/assets/relax/casa/04-bathroom.jpg";
import casaTerrace from "@/assets/relax/casa/05-terrace.jpg";
import casaExterior from "@/assets/relax/casa/06-exterior.jpg";
import casaDetail from "@/assets/relax/casa/07-detail.jpg";
import casaView from "@/assets/relax/casa/08-view.jpg";
import casaOutdoor from "@/assets/relax/casa/09-outdoor.jpg";

import cabanaBedroom from "@/assets/relax/cabana/01-bedroom.jpg";
import cabanaLiving from "@/assets/relax/cabana/02-living.jpg";
import cabanaKitchen from "@/assets/relax/cabana/03-kitchen.jpg";
import cabanaBathroom from "@/assets/relax/cabana/04-bathroom.jpg";
import cabanaTerrace from "@/assets/relax/cabana/05-terrace.jpg";
import cabanaExterior from "@/assets/relax/cabana/06-exterior.jpg";
import cabanaView from "@/assets/relax/cabana/07-view.jpg";
import cabanaLandscape from "@/assets/relax/cabana/08-landscape.jpg";
import cabanaGarden from "@/assets/relax/cabana/09-garden.jpg";
import cabanaDetail from "@/assets/relax/cabana/10-detail.jpg";
import cabanaOutdoor from "@/assets/relax/cabana/11-outdoor.jpg";
import cabanaEntrance from "@/assets/relax/cabana/12-entrance.jpg";

interface Props {
  lang: Language;
  t: RelaxTranslations;
}

const { lang, t } = Astro.props;

const bookingHref = getTranslatedPath("booking", lang);

const subNavLinks = [
  { href: "#casa", label: t.casa.title, image: casaLiving },
  { href: "#cabana", label: t.cabana.title, image: cabanaBedroom },
];

// Preview: curated images shown initially (4th only visible on mobile)
const casaPreview = [casaLiving, casaTerrace, casaExterior, casaBedroom];
const casaRemaining = [casaKitchen, casaBathroom, casaDetail, casaView, casaOutdoor];

const cabanaPreview = [cabanaBedroom, cabanaTerrace, cabanaView, cabanaExterior];
const cabanaRemaining = [cabanaLiving, cabanaKitchen, cabanaBathroom, cabanaLandscape, cabanaGarden, cabanaDetail, cabanaOutdoor, cabanaEntrance];
---

<PageHero title={t.hero.title} subtitle={t.hero.subtitle} ctaLabel={t.hero.bookNow} ctaHref={bookingHref} />

<SubNav links={subNavLinks} />

<!-- Feature Highlights -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern04.src} alt="" class="absolute top-4 md:-top-4 right-4 md:-right-8 w-40 md:w-56 opacity-[0.09] rotate-12 pointer-events-none select-none" />
  <img src={pattern02.src} alt="" class="absolute bottom-4 md:-bottom-6 left-4 md:-left-6 w-24 md:w-36 opacity-[0.10] -rotate-12 pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="grid sm:grid-cols-2 gap-5">
      <div class="flex items-start gap-4 border-l-3 border-primary pl-5 py-1" data-animate data-animate-delay="1">
        <Icon name="lucide:home" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
        <div>
          <h3 class="text-xl font-bold text-text-heading mb-1">{t.features.apartments.title}</h3>
          <p class="text-text-muted text-base leading-relaxed">{t.features.apartments.description}</p>
        </div>
      </div>
      <div class="flex items-start gap-4 border-l-3 border-primary pl-5 py-1" data-animate data-animate-delay="2">
        <Icon name="lucide:check-circle" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
        <div>
          <h3 class="text-xl font-bold text-text-heading mb-1">{t.features.inclusive.title}</h3>
          <p class="text-text-muted text-base leading-relaxed">{t.features.inclusive.description}</p>
        </div>
      </div>
      <div class="flex items-start gap-4 border-l-3 border-primary pl-5 py-1" data-animate data-animate-delay="3">
        <Icon name="lucide:settings" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
        <div>
          <h3 class="text-xl font-bold text-text-heading mb-1">{t.features.equipment.title}</h3>
          <p class="text-text-muted text-base leading-relaxed">{t.features.equipment.description}</p>
        </div>
      </div>
      <div class="flex items-start gap-4 border-l-3 border-primary pl-5 py-1" data-animate data-animate-delay="4">
        <Icon name="lucide:trees" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
        <div>
          <h3 class="text-xl font-bold text-text-heading mb-1">{t.features.nature.title}</h3>
          <p class="text-text-muted text-base leading-relaxed">{t.features.nature.description}</p>
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Intro with Image -->
<section class="py-16 md:py-24 bg-surface relative overflow-hidden">
  <img src={pattern07.src} alt="" class="absolute top-8 left-4 md:-left-6 w-28 md:w-40 opacity-[0.10] rotate-6 pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image -->
      <div class="relative max-w-sm md:max-w-md mx-auto" data-animate>
        <div class="overflow-hidden rounded-lg shadow-xl">
          <Image
            src={introImg}
            alt="Apartment Interior"
            class="w-full h-auto object-cover"
            widths={[300, 500, 800]}
            sizes="(max-width: 768px) 80vw, 28vw"
          />
        </div>
        <div class="overflow-hidden rounded-lg shadow-2xl w-2/3 mr-auto -mt-16 relative z-10 border-2 border-white">
          <Image
            src={natureImg}
            alt="Finca Natur"
            class="w-full h-auto object-cover"
            widths={[200, 300]}
            sizes="(max-width: 768px) 50vw, 18vw"
          />
        </div>
      </div>

      <!-- Text -->
      <div data-animate data-animate-delay="2">
        <h2
          class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
        >
          {t.intro.title}
        </h2>
        <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
          {t.intro.subtitle}
        </p>
        <p class="text-text-muted leading-relaxed">{t.intro.description}</p>
      </div>
    </div>
  </Container>
</section>

<!-- Casa los Castaños -->
<section id="casa" class="py-16 md:py-24 bg-background scroll-mt-4 relative overflow-hidden">
  <img src={pattern06.src} alt="" class="absolute bottom-4 md:-bottom-16 right-4 md:-right-10 w-36 md:w-52 opacity-[0.09] -rotate-6 pointer-events-none select-none" />
  <Container class="relative z-10">
    <!-- Header -->
    <div class="mb-10" data-animate>
      <p
        class="text-xs uppercase tracking-widest text-accent font-medium mb-2"
      >
        {t.casa.label}
      </p>
      <h2
        class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
      >
        {t.casa.title}
      </h2>
      <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
        {t.casa.subtitle}
      </p>
    </div>

    <!-- Gallery preview (3 desktop / 4 mobile) -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 mb-2">
      {
        casaPreview.map((img, i) => (
          <div
            class:list={[
              "overflow-hidden rounded-lg group aspect-[3/2]",
              i === 0 && "md:col-span-2 md:row-span-2 md:aspect-auto",
              i === 3 && "md:hidden",
            ]}
          >
            <Image
              src={img}
              alt={`Casa los Castaños ${i + 1}`}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              widths={[400, 700, 1000]}
              sizes={
                i === 0
                  ? "(max-width: 768px) 50vw, 66vw"
                  : "(max-width: 768px) 50vw, 33vw"
              }
            />
          </div>
        ))
      }
    </div>
    <!-- Remaining gallery images (togglable) -->
    <details class="mb-10 gallery-toggle">
      <summary class="cursor-pointer text-sm text-primary font-medium hover:underline py-2 flex items-center gap-1.5">
        <Icon name="lucide:images" class="w-4 h-4" />
        <span class="gallery-show-label">{t.showAllPhotos}</span>
        <span class="gallery-hide-label hidden">{t.hidePhotos}</span>
      </summary>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 mt-3">
        {
          casaRemaining.map((img, i) => (
            <div class="overflow-hidden rounded-lg group aspect-[3/2]">
              <Image
                src={img}
                alt={`Casa los Castaños ${i + 5}`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                widths={[400, 700, 1000]}
                sizes="(max-width: 768px) 50vw, 33vw"
              />
            </div>
          ))
        }
      </div>
    </details>

    <div class="max-w-4xl mx-auto">
      <!-- Amenities (2-column, accent-border style) -->
      <div class="grid sm:grid-cols-2 gap-4 mb-8">
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:bed-double" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.bedroom}</span>
            <p class="text-text-muted text-sm">{t.casa.bedroom}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:sofa" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.living}</span>
            <p class="text-text-muted text-sm">{t.casa.living}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:cooking-pot" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.kitchen}</span>
            <p class="text-text-muted text-sm">{t.casa.kitchen}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:shower-head" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.bathroom}</span>
            <p class="text-text-muted text-sm">{t.casa.bathroom}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:fence" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.terrace}</span>
            <p class="text-text-muted text-sm">{t.casa.terrace}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:wifi" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.included}</span>
            <p class="text-text-muted text-sm">{t.casa.extras}</p>
          </div>
        </div>
      </div>

      <!-- CTA + Availability -->
      <div class="flex flex-wrap items-center gap-3">
        <button
          type="button"
          class="calendar-trigger inline-flex items-center gap-2 text-primary font-medium border border-primary/30 rounded-full py-2.5 px-6 hover:bg-primary/5 transition-colors duration-300 cursor-pointer"
          data-target="calendar-casa"
        >
          <Icon name="lucide:calendar" class="w-4 h-4" />
          {t.checkAvailability}
        </button>
        <a
          href={`${bookingHref}?property=casa`}
          class="inline-flex items-center gap-2 bg-primary text-white font-medium py-3 px-8 rounded-full hover:bg-primary-dark transition-colors duration-300 shadow-lg"
        >
          {t.casa.cta}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
      <div id="calendar-casa" class="calendar-panel h-0 overflow-hidden mt-4">
          <div class="bg-surface rounded-lg border border-border/50 p-4">
            <div
              id={`smoobuCasa${siteData.accommodation.casa.calendarWidgetId}`}
              class="calendarWidget"
            >
              <div
                class="calendarContent"
                data-load-calendar-url={`https://login.smoobu.com/${lang === "de" ? "de" : lang === "es" ? "es" : "en"}/cockpit/widget/single-calendar/${siteData.accommodation.casa.calendarWidgetId}`}
                data-verification={siteData.accommodation.casa
                  .calendarVerification}
                data-baseUrl="https://login.smoobu.com"
                data-disable-css="false"
              >
              </div>
            </div>
          </div>
      </div>
    </div>
  </Container>
</section>

<!-- Divider -->
<section class="py-16 md:py-24 bg-accent relative overflow-hidden">
  <div
    class="absolute inset-0 bg-repeat opacity-10" style={`background-image: url(${pattern04.src})`}
  >
  </div>
  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto text-center" data-animate>
      <h2
        class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light text-text-heading"
      >
        {t.intro.title}
      </h2>
      <p class="font-serif text-white text-2xl md:text-3xl mb-3">
        {t.intro.subtitle}
      </p>
      <p class="text-text leading-relaxed">{t.intro.description}</p>
    </div>
  </Container>
</section>

<!-- Cabaña en Finca -->
<section id="cabana" class="py-16 md:py-24 bg-surface scroll-mt-4 relative overflow-hidden">
  <img src={pattern04.src} alt="" class="absolute top-10 right-4 md:-right-4 w-36 md:w-48 opacity-[0.09] rotate-[25deg] pointer-events-none select-none" />
  <img src={pattern02.src} alt="" class="absolute bottom-4 md:-bottom-6 left-4 md:-left-6 w-20 md:w-32 opacity-[0.10] rotate-45 pointer-events-none select-none" />
  <Container class="relative z-10">
    <!-- Header -->
    <div class="mb-10" data-animate>
      <p
        class="text-xs uppercase tracking-widest text-accent font-medium mb-2"
      >
        {t.cabana.label}
      </p>
      <h2
        class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
      >
        {t.cabana.title}
      </h2>
      <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
        {t.cabana.subtitle}
      </p>
    </div>

    <!-- Gallery preview (3 desktop / 4 mobile) -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 mb-2">
      {
        cabanaPreview.map((img, i) => (
          <div
            class:list={[
              "overflow-hidden rounded-lg group aspect-[3/2]",
              i === 0 && "md:col-span-2 md:row-span-2 md:aspect-auto",
              i === 3 && "md:hidden",
            ]}
          >
            <Image
              src={img}
              alt={`Cabaña en Finca ${i + 1}`}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              widths={[400, 700, 1000]}
              sizes={
                i === 0
                  ? "(max-width: 768px) 50vw, 66vw"
                  : "(max-width: 768px) 50vw, 33vw"
              }
            />
          </div>
        ))
      }
    </div>
    <!-- Remaining gallery images (togglable) -->
    <details class="mb-10 gallery-toggle">
      <summary class="cursor-pointer text-sm text-primary font-medium hover:underline py-2 flex items-center gap-1.5">
        <Icon name="lucide:images" class="w-4 h-4" />
        <span class="gallery-show-label">{t.showAllPhotos}</span>
        <span class="gallery-hide-label hidden">{t.hidePhotos}</span>
      </summary>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 mt-3">
        {
          cabanaRemaining.map((img, i) => (
            <div class="overflow-hidden rounded-lg group aspect-[3/2]">
              <Image
                src={img}
                alt={`Cabaña en Finca ${i + 5}`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                widths={[400, 700, 1000]}
                sizes="(max-width: 768px) 50vw, 33vw"
              />
            </div>
          ))
        }
      </div>
    </details>

    <div class="max-w-4xl mx-auto">
      <!-- Amenities (2-column, accent-border style) -->
      <div class="grid sm:grid-cols-2 gap-4 mb-8">
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:bed-double" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.bedroom}</span>
            <p class="text-text-muted text-sm">{t.cabana.bedroom}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:sofa" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.living}</span>
            <p class="text-text-muted text-sm">{t.cabana.living}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:cooking-pot" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.kitchen}</span>
            <p class="text-text-muted text-sm">{t.cabana.kitchen}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:shower-head" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.bathroom}</span>
            <p class="text-text-muted text-sm">{t.cabana.bathroom}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:fence" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.terrace}</span>
            <p class="text-text-muted text-sm">{t.cabana.terrace}</p>
          </div>
        </div>
        <div class="flex items-start gap-3 border-l-3 border-primary pl-4 py-1">
          <Icon name="lucide:wifi" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
          <div>
            <span class="text-sm font-bold text-text-heading">{t.amenityLabels.included}</span>
            <p class="text-text-muted text-sm">{t.cabana.extras}</p>
          </div>
        </div>
      </div>

      <!-- CTA + Availability -->
      <div class="flex flex-wrap items-center gap-3">
        <button
          type="button"
          class="calendar-trigger inline-flex items-center gap-2 text-primary font-medium border border-primary/30 rounded-full py-2.5 px-6 hover:bg-primary/5 transition-colors duration-300 cursor-pointer"
          data-target="calendar-cabana"
        >
          <Icon name="lucide:calendar" class="w-4 h-4" />
          {t.checkAvailability}
        </button>
        <a
          href={`${bookingHref}?property=cabana`}
          class="inline-flex items-center gap-2 bg-primary text-white font-medium py-3 px-8 rounded-full hover:bg-primary-dark transition-colors duration-300 shadow-lg"
        >
          {t.cabana.cta}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
      <div id="calendar-cabana" class="calendar-panel h-0 overflow-hidden mt-4">
          <div class="bg-background rounded-lg border border-border/50 p-4">
            <div
              id={`smoobuCabana${siteData.accommodation.cabana.calendarWidgetId}`}
              class="calendarWidget"
            >
              <div
                class="calendarContent"
                data-load-calendar-url={`https://login.smoobu.com/${lang === "de" ? "de" : lang === "es" ? "es" : "en"}/cockpit/widget/single-calendar/${siteData.accommodation.cabana.calendarWidgetId}`}
                data-verification={siteData.accommodation.cabana
                  .calendarVerification}
                data-baseUrl="https://login.smoobu.com"
                data-disable-css="false"
              >
              </div>
            </div>
          </div>
      </div>
    </div>
  </Container>
</section>

<script>
  document.querySelectorAll('.gallery-toggle').forEach((details) => {
    details.addEventListener('toggle', () => {
      const showLabel = details.querySelector('.gallery-show-label');
      const hideLabel = details.querySelector('.gallery-hide-label');
      if ((details as HTMLDetailsElement).open) {
        showLabel?.classList.add('hidden');
        hideLabel?.classList.remove('hidden');
      } else {
        showLabel?.classList.remove('hidden');
        hideLabel?.classList.add('hidden');
      }
    });
  });

  document.querySelectorAll('.calendar-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.target;
      if (!targetId) return;
      const panel = document.getElementById(targetId);
      if (!panel) return;
      panel.classList.toggle('h-0');
      panel.classList.toggle('overflow-hidden');
    });
  });
</script>
<script is:inline src="https://login.smoobu.com/js/Apartment/CalendarWidget.js"></script>
