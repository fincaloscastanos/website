---
import type { BookingTranslations } from "./booking.i18n";
import type { Language } from "@/lib/i18n";
import Container from "@/components/ui/Container.astro";

interface Props {
  lang: Language;
  t: BookingTranslations;
}

const { lang, t } = Astro.props;
---

<!-- Booking Widget -->
<section class="pt-10 md:pt-14 pb-16 md:pb-24 bg-background">
  <Container>
    <h1 class="text-2xl md:text-3xl font-serif text-text-heading mb-8 md:mb-10">
      {t.hero.title}
    </h1>
    <div id="apartmentIframeAll"></div>
  </Container>
</section>

<script
  is:inline
  src="https://login.smoobu.com/js/Settings/BookingToolIframe.js"></script>
<script is:inline>
  BookingToolIframe.initialize({
    url: "https://login.smoobu.com/en/booking-tool/iframe/1634876",
    baseUrl: "https://login.smoobu.com",
    target: "#apartmentIframeAll",
  });
</script>
