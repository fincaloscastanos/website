---
import type { BookingTranslations } from "./booking.i18n";
import type { Language } from "@/lib/i18n";
import Container from "@/components/ui/Container.astro";
import PrivacyGate from "@/components/ui/PrivacyGate.astro";
import { siteData } from "@/data/site";
import { getTranslatedPath } from "@/lib/registry";

interface Props {
  lang: Language;
  t: BookingTranslations;
}

const { lang, t } = Astro.props;

const { accommodation } = siteData;
const bookingBase = getTranslatedPath("booking", lang);
const smoobuBaseUrl = `https://login.smoobu.com/${lang}/booking-tool/iframe/${accommodation.bookingChannelId}`;
---

<!-- Booking Widget -->
<section class="pt-10 md:pt-14 pb-16 md:pb-24 bg-background">
  <Container>
    <div
      class="mb-8 md:mb-10"
      id="booking-header"
      data-title-template={t.hero.titleProperty}
      data-base-url={smoobuBaseUrl}
      data-casa={accommodation.casa.name}
      data-cabana={accommodation.cabana.name}
      data-casa-id={String(accommodation.casa.calendarWidgetId)}
      data-cabana-id={String(accommodation.cabana.calendarWidgetId)}
    >
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-sans text-text-heading"
        id="booking-title"
      >
        {t.hero.titleAll}
      </h1>
      <a
        id="booking-back"
        href={bookingBase}
        class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-primary transition-colors mt-3"
        style="display:none"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path></svg
        >
        {t.booking.allProperties}
      </a>
    </div>

    <PrivacyGate
      consentKey="smoobu-consent"
      scripts={["https://login.smoobu.com/js/Settings/BookingToolIframe.js"]}
      title={t.consent.title}
      description={t.consent.description}
      buttonLabel={t.consent.button}
    >
      <div id="apartmentIframeAll"></div>
    </PrivacyGate>
  </Container>
</section>

<script is:inline>
  document.addEventListener("privacy-gate:ready", function handler(e) {
    var gate = e.target;
    if (!gate.matches || !gate.matches('[data-consent-key="smoobu-consent"]'))
      return;
    // Only run on the booking page (has #booking-header)
    var hdr = document.getElementById("booking-header");
    if (!hdr || !window.BookingToolIframe) return;

    var baseUrl = hdr.getAttribute("data-base-url");
    var params = new URLSearchParams(window.location.search);
    var property = params.get("property");

    var url = baseUrl;
    if (property === "casa") url += "/" + hdr.getAttribute("data-casa-id");
    else if (property === "cabana")
      url += "/" + hdr.getAttribute("data-cabana-id");

    BookingToolIframe.initialize({
      url: url,
      baseUrl: "https://login.smoobu.com",
      target: "#apartmentIframeAll",
    });

    if (property) {
      var name = hdr.getAttribute("data-" + property);
      if (name) {
        var tpl = hdr.getAttribute("data-title-template");
        document.getElementById("booking-title").textContent = tpl.replace(
          "{name}",
          name,
        );
      }
      document.getElementById("booking-back").style.display = "";
    }
  });
</script>
