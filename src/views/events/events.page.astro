---
import type { EventsTranslations } from "./events.i18n";
import type { Language } from "@/lib/i18n";
import { Image } from "astro:assets";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";
import { Icon } from "astro-icon/components";
import { getTranslatedPath } from "@/lib/registry";

import tentInteriorImg from "@/assets/events/tent-interior.jpg";
import tentExteriorImg from "@/assets/events/tent-exterior.jpg";
import celebrationImg from "@/assets/events/celebration.jpg";
import setupImg from "@/assets/events/setup.jpg";

import gallery01 from "@/assets/events/gallery-01.jpg";
import gallery02 from "@/assets/events/gallery-02.jpg";
import gallery03 from "@/assets/events/gallery-03.jpg";
import gallery04 from "@/assets/events/gallery-04.jpg";
import gallery05 from "@/assets/events/gallery-05.jpg";
import gallery06 from "@/assets/events/gallery-06.jpg";
import gallery07 from "@/assets/events/gallery-07.jpg";
import gallery08 from "@/assets/events/gallery-08.jpg";

import pattern02 from "@/assets/patterns/pattern-02.svg";
import pattern04 from "@/assets/patterns/pattern-04.svg";
import pattern07 from "@/assets/patterns/pattern-07.svg";

interface Props {
  lang: Language;
  t: EventsTranslations;
}

const { lang, t } = Astro.props;

const contactHref = getTranslatedPath("contact", lang);

const features = [
  { icon: "lucide:users", label: t.features.capacity },
  { icon: "lucide:accessibility", label: t.features.accessible },
  { icon: "lucide:car", label: t.features.parking },
  { icon: "lucide:thermometer", label: t.features.climate },
  { icon: "lucide:wifi", label: t.features.wifi },
  { icon: "lucide:bath", label: t.features.wc },
];

const galleryImages = [
  gallery01,
  gallery02,
  gallery03,
  gallery04,
  gallery05,
  gallery06,
  gallery07,
  gallery08,
];
---

<PageHero title={t.hero.title} subtitle={t.hero.subtitle} ctaLabel={t.closing.cta} ctaHref={contactHref} />

<!-- Intro -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern04.src} alt="" class="absolute top-4 md:-top-4 right-4 md:-right-8 w-40 md:w-56 opacity-[0.09] rotate-12 pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div class="space-y-5" data-animate>
        <p class="text-text-muted leading-relaxed">{t.intro.p1}</p>
        <p class="text-text-muted leading-relaxed">{t.intro.p2}</p>
      </div>

      <!-- Images -->
      <div class="relative max-w-sm md:max-w-md mx-auto" data-animate data-animate-delay="2">
        <div class="overflow-hidden shadow-xl">
          <Image
            src={tentExteriorImg}
            alt="Eventzelt"
            class="w-full h-auto object-cover"
            widths={[300, 500, 800]}
            sizes="(max-width: 768px) 80vw, 28vw"
          />
        </div>
        <div class="overflow-hidden shadow-2xl w-2/3 mr-auto -mt-16 relative z-10 border border-border">
          <Image
            src={tentInteriorImg}
            alt="Inneneinrichtung"
            class="w-full h-auto object-cover"
            widths={[200, 300]}
            sizes="(max-width: 768px) 50vw, 18vw"
          />
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Features -->
<section class="py-16 md:py-24 bg-surface">
  <Container>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
      {
        features.map(({ icon, label }, i) => (
          <div class="flex items-center gap-3 bg-background rounded-lg p-4 shadow-sm" data-animate data-animate-delay={`${i + 1}`}>
            <Icon name={icon} class="w-6 h-6 text-primary shrink-0" />
            <span class="text-text-heading font-medium text-sm">{label}</span>
          </div>
        ))
      }
    </div>
  </Container>
</section>

<!-- Feiern mit Stil -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern02.src} alt="" class="absolute bottom-4 md:-bottom-6 left-4 md:-left-6 w-24 md:w-36 opacity-[0.10] -rotate-12 pointer-events-none select-none" />
  <img src={pattern07.src} alt="" class="absolute top-8 right-4 md:-right-6 w-28 md:w-40 opacity-[0.10] rotate-6 pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image -->
      <div class="relative order-2 md:order-1" data-animate>
        <div class="overflow-hidden shadow-xl">
          <Image
            src={celebrationImg}
            alt="Veranstaltung"
            class="w-full h-auto object-cover"
            widths={[500, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
        <div class="overflow-hidden shadow-2xl w-2/3 ml-auto -mt-16 relative z-10 border border-border">
          <Image
            src={setupImg}
            alt="Event Vorbereitung"
            class="w-full h-auto object-cover"
            widths={[300, 500]}
            sizes="(max-width: 768px) 66vw, 33vw"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="order-1 md:order-2" data-animate data-animate-delay="2">
        <h2
          class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
        >
          {t.style.title}
        </h2>
        <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
          {t.style.subtitle}
        </p>
        <div class="space-y-5">
          <p class="text-text-muted leading-relaxed">{t.style.p1}</p>
          <p class="text-text-muted leading-relaxed">{t.style.p2}</p>
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Gallery -->
<section class="py-16 md:py-24 bg-surface relative overflow-hidden">
  <img src={pattern04.src} alt="" class="absolute bottom-4 md:-bottom-8 left-4 md:-left-8 w-36 md:w-48 opacity-[0.06] rotate-[-20deg] pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4">
      {
        galleryImages.map((img, i) => (
          <div class="overflow-hidden shadow-lg break-inside-avoid" data-animate="fade">
            <Image
              src={img}
              alt={`Finca Los Castaños Event ${i + 1}`}
              class="w-full h-auto object-cover hover:scale-105 transition-transform duration-500"
              widths={[300, 500]}
              sizes="(max-width: 768px) 50vw, 25vw"
            />
          </div>
        ))
      }
    </div>
  </Container>
</section>

<!-- CTA -->
<section class="py-16 md:py-24 bg-accent relative overflow-hidden">
  <div
    class="absolute inset-0 bg-repeat opacity-10" style={`background-image: url(${pattern04.src})`}
  >
  </div>
  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto text-center" data-animate>
      <p class="text-xl md:text-2xl text-text leading-relaxed mb-8">
        {t.closing.text}
      </p>
      <a
        href={contactHref}
        class="inline-flex items-center gap-2 bg-white text-text-heading font-bold py-3 px-8 rounded-full hover:bg-white/80 transition-colors duration-300 shadow-lg"
      >
        {t.closing.cta}
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </Container>
</section>
