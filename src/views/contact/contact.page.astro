---
import type { ContactTranslations } from "./contact.i18n";
import type { Language } from "@/lib/i18n";
import Container from "@/components/ui/Container.astro";
import PrivacyMap from "@/components/ui/PrivacyMap.astro";
import { Icon } from "astro-icon/components";
import { siteData } from "@/data/site";

import pattern04 from "@/assets/patterns/pattern-04.svg";
import pattern07 from "@/assets/patterns/pattern-07.svg";

interface Props {
  lang: Language;
  t: ContactTranslations;
}

const { lang, t } = Astro.props;
---

<!-- Hero -->
<section class="py-16 md:py-24 bg-surface">
  <Container>
    <div class="text-center max-w-2xl mx-auto">
      <h1
        class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-bold"
      >
        {t.hero.title}
      </h1>
      <p class="font-serif text-primary text-2xl md:text-3xl mb-3">
        {t.hero.subtitle}
      </p>
    </div>
  </Container>
</section>

<!-- Contact Details + Map -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern04.src} alt="" class="absolute top-4 md:-top-4 right-4 md:-right-8 w-40 md:w-56 opacity-[0.09] rotate-12 pointer-events-none select-none" />
  <img src={pattern07.src} alt="" class="absolute bottom-4 md:-bottom-4 left-4 md:-left-6 w-28 md:w-36 opacity-[0.10] rotate-[-15deg] pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Map -->
      <div
        class="rounded-lg overflow-hidden shadow-lg h-80 md:h-full md:min-h-[32rem]"
        data-animate
      >
        <PrivacyMap
          url={siteData.contact.googleMapsEmbed}
          loadMap={t.map.loadMap}
          accept={t.map.accept}
          showMap={t.map.showMap}
        />
      </div>

      <!-- Contact Info -->
      <div class="flex flex-col gap-4" data-animate data-animate-delay="2">
        <!-- Address -->
        <a
          href={siteData.contact.googleMaps}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-4 p-5 bg-surface rounded-lg border border-border/50 hover:border-primary/30 hover:shadow-md transition-all"
        >
          <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-primary" />
          </div>
          <div>
            <span class="block text-xs uppercase tracking-widest text-primary font-medium mb-1">{t.info.addressLabel}</span>
            <span class="text-base text-text-muted group-hover:text-text transition-colors leading-relaxed">{siteData.contact.address}</span>
          </div>
        </a>

        <!-- Email -->
        <a
          href={`mailto:${siteData.contact.email}`}
          class="group flex items-start gap-4 p-5 bg-surface rounded-lg border border-border/50 hover:border-primary/30 hover:shadow-md transition-all"
        >
          <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
            <Icon name="lucide:mail" class="w-5 h-5 text-primary" />
          </div>
          <div>
            <span class="block text-xs uppercase tracking-widest text-primary font-medium mb-1">{t.info.emailLabel}</span>
            <span class="text-base text-text-muted group-hover:text-text transition-colors">{siteData.contact.email}</span>
          </div>
        </a>

        <!-- Phone -->
        <div class="p-5 bg-surface rounded-lg border border-border/50">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
              <Icon name="lucide:phone" class="w-5 h-5 text-primary" />
            </div>
            <span class="text-xs uppercase tracking-widest text-primary font-medium">Telefon</span>
          </div>
          <div class="space-y-2 pl-14">
            <a href={`tel:${siteData.contact.phone.replaceAll(" ", "")}`} class="flex justify-between items-center text-base text-text-muted hover:text-text transition-colors">
              <span class="text-sm text-text-muted/70">{t.info.toursLabel}</span>
              <span>{siteData.contact.phone}</span>
            </a>
            <a href={`tel:${siteData.contact.phoneSales.replaceAll(" ", "")}`} class="flex justify-between items-center text-base text-text-muted hover:text-text transition-colors">
              <span class="text-sm text-text-muted/70">{t.info.salesLabel}</span>
              <span>{siteData.contact.phoneSales}</span>
            </a>
            <a href={`tel:${siteData.contact.phoneEvents.replaceAll(" ", "")}`} class="flex justify-between items-center text-base text-text-muted hover:text-text transition-colors">
              <span class="text-sm text-text-muted/70">{t.info.eventsLabel}</span>
              <span>{siteData.contact.phoneEvents}</span>
            </a>
          </div>
        </div>

        <!-- Opening Hours -->
        <div class="p-5 bg-surface rounded-lg border border-border/50">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
              <Icon name="lucide:clock" class="w-5 h-5 text-primary" />
            </div>
            <span class="text-xs uppercase tracking-widest text-primary font-medium">{t.hours.title}</span>
          </div>
          <div class="space-y-2 pl-14">
            <p class="text-base text-text-muted">{t.hours.weekdays.replace("{start}", siteData.hours.weekdays.start).replace("{end}", siteData.hours.weekdays.end)}</p>
            <p class="text-base text-text-muted">{t.hours.weekends.replace("{start}", siteData.hours.weekends.start).replace("{end}", siteData.hours.weekends.end)}</p>
          </div>
        </div>

        <!-- WhatsApp CTA -->
        <a
          href={`https://wa.me/${siteData.contact.whatsapp.replaceAll(" ", "").replace("+", "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 bg-primary text-white font-medium py-3.5 px-8 rounded-lg hover:bg-primary-dark transition-colors text-base shadow-lg"
        >
          <Icon name="simple-icons:whatsapp" class="w-5 h-5" />
          WhatsApp
        </a>

      </div>
    </div>
  </Container>
</section>
