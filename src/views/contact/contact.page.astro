---
import type { ContactTranslations } from "./contact.i18n";
import type { Language } from "@/lib/i18n";
import Container from "@/components/ui/Container.astro";
import PrivacyMap from "@/components/ui/PrivacyMap.astro";
import { Icon } from "astro-icon/components";
import { siteData } from "@/data/site";

import pattern04 from "@/assets/patterns/pattern-04.svg";
import pattern07 from "@/assets/patterns/pattern-07.svg";

interface Props {
  lang: Language;
  t: ContactTranslations;
}

const { lang, t } = Astro.props;
---

<!-- Hero -->
<section class="py-16 md:py-24 bg-surface">
  <Container>
    <div class="text-center max-w-2xl mx-auto">
      <h1
        class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-bold"
      >
        {t.hero.title}
      </h1>
      <p class="font-serif text-primary text-2xl md:text-3xl mb-3">
        {t.hero.subtitle}
      </p>
    </div>
  </Container>
</section>

<!-- Contact Details -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern04.src} alt="" class="absolute top-4 md:-top-4 right-4 md:-right-8 w-40 md:w-56 opacity-[0.09] rotate-12 pointer-events-none select-none" />
  <img src={pattern07.src} alt="" class="absolute bottom-4 md:-bottom-4 left-4 md:-left-6 w-28 md:w-36 opacity-[0.10] rotate-[-15deg] pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-3 gap-12 lg:gap-16">
      <!-- Column 1: Address & Email -->
      <div class="space-y-8" data-animate data-animate-delay="1">
        <div>
          <div class="flex items-center gap-3 mb-3">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-primary" />
            <span
              class="text-xs uppercase tracking-widest text-primary font-medium"
              >{t.info.addressLabel}</span
            >
          </div>
          <a
            href={siteData.contact.googleMaps}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-primary transition-colors leading-relaxed"
          >
            {siteData.contact.address}
          </a>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-3">
            <Icon name="lucide:mail" class="w-5 h-5 text-primary" />
            <span
              class="text-xs uppercase tracking-widest text-primary font-medium"
              >{t.info.emailLabel}</span
            >
          </div>
          <a
            href={`mailto:${siteData.contact.email}`}
            class="text-text-muted hover:text-primary transition-colors"
          >
            {siteData.contact.email}
          </a>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-3">
            <Icon name="lucide:message-circle" class="w-5 h-5 text-primary" />
            <span
              class="text-xs uppercase tracking-widest text-primary font-medium"
              >{t.info.whatsappLabel}</span
            >
          </div>
          <a
            href={`https://wa.me/${siteData.contact.whatsapp.replaceAll(" ", "").replace("+", "")}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-primary transition-colors"
          >
            {siteData.contact.whatsapp}
          </a>
        </div>
      </div>

      <!-- Column 2: Phone Numbers & Hours -->
      <div class="space-y-8" data-animate data-animate-delay="2">
        <div>
          <div class="flex items-center gap-3 mb-3">
            <Icon name="lucide:phone" class="w-5 h-5 text-primary" />
            <span
              class="text-xs uppercase tracking-widest text-primary font-medium"
              >{t.info.toursLabel}</span
            >
          </div>
          <a
            href={`tel:${siteData.contact.phone.replaceAll(" ", "")}`}
            class="text-text-muted hover:text-primary transition-colors"
            >{siteData.contact.phone}</a
          >
        </div>

        <div>
          <div class="flex items-center gap-3 mb-3">
            <Icon name="lucide:phone" class="w-5 h-5 text-primary" />
            <span
              class="text-xs uppercase tracking-widest text-primary font-medium"
              >{t.info.salesLabel}</span
            >
          </div>
          <a
            href={`tel:${siteData.contact.phoneSales.replaceAll(" ", "")}`}
            class="text-text-muted hover:text-primary transition-colors"
            >{siteData.contact.phoneSales}</a
          >
        </div>

        <div>
          <div class="flex items-center gap-3 mb-3">
            <Icon name="lucide:phone" class="w-5 h-5 text-primary" />
            <span
              class="text-xs uppercase tracking-widest text-primary font-medium"
              >{t.info.eventsLabel}</span
            >
          </div>
          <a
            href={`tel:${siteData.contact.phoneEvents.replaceAll(" ", "")}`}
            class="text-text-muted hover:text-primary transition-colors"
            >{siteData.contact.phoneEvents}</a
          >
        </div>
      </div>

      <!-- Column 3: Hours & Social -->
      <div class="space-y-8" data-animate data-animate-delay="3">
        <div>
          <div class="flex items-center gap-3 mb-3">
            <Icon name="lucide:clock" class="w-5 h-5 text-primary" />
            <span
              class="text-xs uppercase tracking-widest text-primary font-medium"
              >{t.hours.title}</span
            >
          </div>
          <p class="text-text-muted">{t.hours.weekdays.replace("{start}", siteData.hours.weekdays.start).replace("{end}", siteData.hours.weekdays.end)}</p>
          <p class="text-text-muted">{t.hours.weekends.replace("{start}", siteData.hours.weekends.start).replace("{end}", siteData.hours.weekends.end)}</p>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-3">
            <Icon name="lucide:share-2" class="w-5 h-5 text-primary" />
            <span
              class="text-xs uppercase tracking-widest text-primary font-medium"
              >{t.social.title}</span
            >
          </div>
          <div class="flex gap-4">
            <a
              href={siteData.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-text-muted hover:text-primary transition-colors"
            >
              <Icon name="lucide:instagram" class="w-5 h-5" />
              Instagram
            </a>
            <a
              href={siteData.social.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-text-muted hover:text-primary transition-colors"
            >
              <Icon name="lucide:facebook" class="w-5 h-5" />
              Facebook
            </a>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Map -->
<section class="py-16 md:py-24 bg-surface">
  <Container>
    <h2 class="text-3xl md:text-4xl lg:text-5xl text-center mb-12" data-animate="fade">
      {t.map.title}
    </h2>
    <div
      class="rounded-lg overflow-hidden shadow-lg h-80 md:h-[28rem] lg:h-[32rem]"
    >
      <PrivacyMap
        url={siteData.contact.googleMapsEmbed}
        loadMap={t.map.loadMap}
        accept={t.map.accept}
        showMap={t.map.showMap}
      />
    </div>
  </Container>
</section>
