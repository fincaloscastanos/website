---
import type { ExperienceTranslations } from "./experience.i18n";
import type { Language } from "@/lib/i18n";
import { Image } from "astro:assets";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";
import SubNav from "@/components/ui/SubNav.astro";
import { Icon } from "astro-icon/components";
import { getTranslatedPath } from "@/lib/registry";

import plantationTour from "@/assets/experience/plantation-tour.jpg";
import coffeeProduction from "@/assets/experience/coffee-production.png";
import plantationView from "@/assets/experience/plantation-view.jpg";
import coffeeDetail from "@/assets/experience/coffee-detail.jpg";
import fincaLandscape from "@/assets/experience/finca-landscape.jpg";
import fincaDetail from "@/assets/experience/finca-detail.jpg";
import fincaPlants from "@/assets/experience/finca-plants.jpg";
import plantationClose from "@/assets/coffee-tour/plantation.jpg";
import tourMap from "@/assets/experience/tour-map.webp";

import coffeeTourImg from "@/assets/coffee-tour/tasting.jpg";
import eventsImg from "@/assets/events/celebration.jpg";

import pattern02 from "@/assets/patterns/pattern-02.svg";
import pattern04 from "@/assets/patterns/pattern-04.svg";
import pattern06 from "@/assets/patterns/pattern-06.svg";
import pattern07 from "@/assets/patterns/pattern-07.svg";

interface Props {
  lang: Language;
  t: ExperienceTranslations;
}

const { lang, t } = Astro.props;

const pdfByLang: Record<Language, string> = {
  de: "/Finca-Los-Castanos-German.pdf",
  en: "/Finca-Los-Castanos-English.pdf",
  es: "/Finca-Los-Castanos-Spanish.pdf",
};

const subNavLinks = [
  {
    href: getTranslatedPath("coffee-tour", lang),
    label: t.hero.cards.coffeeTour.title,
    image: coffeeTourImg,
  },
  {
    href: getTranslatedPath("events", lang),
    label: t.hero.cards.events.title,
    image: eventsImg,
  },
];
---

<PageHero title={t.hero.title} subtitle={t.hero.subtitle} />

<SubNav links={subNavLinks} />

<!-- Intro: Kaffeetour -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern07.src} alt="" class="absolute top-4 md:-top-4 right-4 md:-right-8 w-28 md:w-40 opacity-[0.10] rotate-12 pointer-events-none select-none" />
  <img src={pattern02.src} alt="" class="absolute bottom-4 md:-bottom-6 left-4 md:-left-6 w-20 md:w-32 opacity-[0.10] -rotate-12 pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div class="space-y-5" data-animate>
        <p class="text-text-muted leading-relaxed">{t.intro.p1}</p>
        <p class="text-text-muted leading-relaxed">{t.intro.p2}</p>
        <p class="text-text-muted leading-relaxed">{t.intro.p3}</p>
        <p class="text-text-muted leading-relaxed">{t.intro.p4}</p>
        <p class="text-text-muted leading-relaxed">{t.intro.p5}</p>
        <p class="text-text-muted leading-relaxed">{t.intro.p6}</p>
        <p class="text-text-muted leading-relaxed">{t.intro.p7}</p>
      </div>

      <!-- Images -->
      <div class="relative max-w-sm md:max-w-md mx-auto" data-animate data-animate-delay="2">
        <div class="overflow-hidden shadow-xl border border-border">
          <Image
            src={plantationTour}
            alt="Plantage"
            class="w-full h-auto object-cover"
            widths={[300, 500, 800]}
            sizes="(max-width: 768px) 80vw, 28vw"
          />
        </div>
        <div class="overflow-hidden shadow-2xl w-2/3 mr-auto -mt-16 relative z-10 border border-border">
          <Image
            src={coffeeProduction}
            alt="Kaffeeherstellung"
            class="w-full h-auto object-cover"
            widths={[200, 300]}
            sizes="(max-width: 768px) 50vw, 18vw"
          />
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Kaffeeträume -->
<section class="py-16 md:py-24 bg-surface relative overflow-hidden">
  <img src={pattern04.src} alt="" class="absolute top-8 left-4 md:-left-8 w-36 md:w-48 opacity-[0.09] rotate-[-15deg] pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image -->
      <div class="relative order-2 md:order-1" data-animate>
        <div class="overflow-hidden shadow-xl border border-border">
          <Image
            src={plantationView}
            alt="Plantage im Valle de Agaete"
            class="w-full h-auto object-cover"
            widths={[500, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
        <div class="overflow-hidden shadow-2xl w-2/3 ml-auto -mt-16 relative z-10 border border-border">
          <Image
            src={coffeeDetail}
            alt="Kaffeedetail"
            class="w-full h-auto object-cover"
            widths={[300, 500]}
            sizes="(max-width: 768px) 66vw, 33vw"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="order-1 md:order-2" data-animate data-animate-delay="2">
        <h2
          class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
        >
          {t.dreams.title}
        </h2>
        <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
          {t.dreams.subtitle}
        </p>
        <div class="space-y-5">
          <p class="text-text-muted leading-relaxed">{t.dreams.p1}</p>
          <p class="text-text-muted leading-relaxed">{t.dreams.p2}</p>
          <p class="text-text-muted leading-relaxed">{t.dreams.p3}</p>
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Klima -->
<section class="py-16 md:py-24 bg-background">
  <Container>
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div data-animate>
        <h2
          class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
        >
          {t.climate.title}
        </h2>
        <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
          {t.climate.subtitle}
        </p>
        <div class="space-y-5">
          <p class="text-text-muted leading-relaxed">{t.climate.p1}</p>
          <p class="text-text-muted leading-relaxed">{t.climate.p2}</p>
        </div>
      </div>

      <!-- Image -->
      <div class="relative" data-animate data-animate-delay="2">
        <div class="overflow-hidden shadow-xl border border-border">
          <Image
            src={fincaLandscape}
            alt="Gran Canaria Landschaft"
            class="w-full h-auto object-cover"
            widths={[500, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
        <div class="overflow-hidden shadow-2xl w-2/3 mr-auto -mt-16 relative z-10 border border-border">
          <Image
            src={fincaDetail}
            alt="Finca Detail"
            class="w-full h-auto object-cover"
            widths={[300, 500]}
            sizes="(max-width: 768px) 66vw, 33vw"
          />
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Exklusiver Kaffeeanbau -->
<section class="py-16 md:py-24 bg-accent relative overflow-hidden">
  <div
    class="absolute inset-0 bg-repeat opacity-10" style={`background-image: url(${pattern04.src})`}
  >
  </div>
  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto text-center" data-animate>
      <h2
        class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light text-text-heading"
      >
        {t.exclusive.title}
      </h2>
      <p class="font-serif text-white text-2xl md:text-3xl mb-3">
        {t.exclusive.subtitle}
      </p>
      <p class="text-text leading-relaxed mb-5">{t.exclusive.p1}</p>
      <p class="text-text leading-relaxed">{t.exclusive.p2}</p>
    </div>
  </Container>
</section>

<!-- Besondere Einblicke -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern06.src} alt="" class="absolute bottom-4 md:-bottom-16 right-4 md:-right-10 w-36 md:w-52 opacity-[0.09] -rotate-6 pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="text-center mb-12" data-animate>
      <h2
        class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
      >
        {t.insights.title}
      </h2>
      <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
        {t.insights.subtitle}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-start">
      <!-- Image -->
      <div class="relative" data-animate>
        <div class="overflow-hidden shadow-xl border border-border">
          <Image
            src={fincaPlants}
            alt="Kaffeepflanzen"
            class="w-full h-auto object-cover"
            widths={[500, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
        <div class="overflow-hidden shadow-2xl w-2/3 ml-auto -mt-16 relative z-10 border border-border">
          <Image
            src={plantationClose}
            alt="Kaffeeplantage Nahaufnahme"
            class="w-full h-auto object-cover"
            widths={[300, 500]}
            sizes="(max-width: 768px) 66vw, 33vw"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="space-y-5" data-animate data-animate-delay="2">
        <p class="text-text-muted leading-relaxed">{t.insights.p1}</p>
        <p class="text-text-muted leading-relaxed">{t.insights.p2}</p>
        <p class="text-text-muted leading-relaxed">{t.insights.p3}</p>
        <p class="text-text-muted leading-relaxed">{t.insights.p4}</p>
      </div>
    </div>
  </Container>
</section>

<!-- Geführte Tour / Karte -->
<section class="py-16 md:py-24 bg-surface relative overflow-hidden">
  <img src={pattern02.src} alt="" class="absolute top-10 right-4 md:-right-4 w-20 md:w-32 opacity-[0.12] rotate-45 pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div data-animate>
        <h2
          class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
        >
          {t.tour.title}
        </h2>
        <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
          {t.tour.subtitle}
        </p>
        <p class="text-text-muted leading-relaxed mb-8">{t.tour.description}</p>
        <a
          href={pdfByLang[lang]}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary text-white font-medium py-3 px-8 rounded-none hover:bg-primary-dark transition-colors duration-300 shadow-lg"
        >
          <Icon name="lucide:download" class="w-4 h-4" />
          {t.tour.cta}
        </a>
      </div>

      <!-- Tour Map -->
      <div class="overflow-hidden shadow-xl" data-animate data-animate-delay="2">
        <Image
          src={tourMap}
          alt="Karte der Führung"
          class="w-full h-auto object-cover"
          widths={[500, 800]}
          sizes="(max-width: 768px) 100vw, 50vw"
        />
      </div>
    </div>
  </Container>
</section>

<!-- Röstung & Geschmack -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern07.src} alt="" class="absolute bottom-4 md:-bottom-4 left-4 md:-left-6 w-28 md:w-36 opacity-[0.10] rotate-[-15deg] pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto text-center" data-animate>
      <h2
        class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
      >
        {t.roasting.title}
      </h2>
      <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
        {t.roasting.subtitle}
      </p>
      <p class="text-text-muted leading-relaxed mb-5">{t.roasting.p1}</p>
      <p class="text-text-muted leading-relaxed mb-10">{t.roasting.p2}</p>
      <p class="text-2xl md:text-3xl font-serif text-text-heading italic">
        {t.roasting.cta}
      </p>
    </div>
  </Container>
</section>
