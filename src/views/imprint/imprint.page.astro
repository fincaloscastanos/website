---
import type { ImprintTranslations } from "./imprint.i18n";
import type { Language } from "@/lib/i18n";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";

import pattern02 from "@/assets/patterns/pattern-02.svg";
import pattern07 from "@/assets/patterns/pattern-07.svg";

interface Props {
  lang: Language;
  t: ImprintTranslations;
}

const { lang, t } = Astro.props;
---

<PageHero title={t.title} subtitle={t.subtitle} />

<!-- Content -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern07.src} alt="" class="absolute top-4 md:-top-4 right-4 md:-right-8 w-28 md:w-40 opacity-[0.09] rotate-12 pointer-events-none select-none" />
  <img src={pattern02.src} alt="" class="absolute bottom-4 md:-bottom-6 left-4 md:-left-6 w-20 md:w-32 opacity-[0.10] -rotate-12 pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto prose prose-lg prose-olive">
      <!-- I. General Information -->
      <h2>{t.general.heading}</h2>
      <p>{t.general.intro}</p>
      <p>{t.general.ownerIntro}</p>
      <p>
        <strong>AGAMOG INVERSIONES SLU</strong><br />
        CIF: B21690888<br />
        Camino de Los Romeros, s/n<br />
        35489 Agaete – Las Palmas de Gran Canaria ({
          lang === "de" ? "Spanien" : lang === "en" ? "Spain" : "España"
        })
      </p>
      <p>
        {
          lang === "de" ? "Telefonnummer" : lang === "en" ? "Phone" : "Teléfono"
        }: +34 600 08 07 31<br />
        {
          lang === "de"
            ? "E-Mail-Kontakt"
            : lang === "en"
              ? "Email"
              : "Correo electrónico"
        }: info@fincaloscastanos.com
      </p>

      <!-- II. Terms -->
      <h2>{t.terms.heading}</h2>

      <h3>{t.terms.purposeTitle}</h3>
      <p>{t.terms.purposeText}</p>
      <p>{t.terms.rightsText}</p>
      <p>{t.terms.accessText}</p>
      <p>{t.terms.registrationText}</p>

      <h3>{t.terms.userTitle}</h3>
      <p>{t.terms.userText}</p>
      <p>{t.terms.userSiteText}</p>
      <ul>
        <li>{t.terms.userObligation1}</li>
        <li>{t.terms.userObligation2}</li>
      </ul>
      <p>{t.terms.moderationText}</p>
      <p>{t.terms.noRelationText}</p>
      <p>{t.terms.legalAgeText}</p>

      <!-- III. Access -->
      <h2>{t.access.heading}</h2>
      <p>{t.access.text1}</p>
      <p>{t.access.text2}</p>

      <!-- IV. Links -->
      <h2>{t.links.heading}</h2>
      <p>{t.links.text1}</p>
      <p>{t.links.text2}</p>
      <ul>
        <li>{t.links.rule1}</li>
        <li>{t.links.rule2}</li>
      </ul>

      <!-- V. IP -->
      <h2>{t.ip.heading}</h2>
      <p>{t.ip.text}</p>

      <!-- VI. Legal -->
      <h2>{t.legal.heading}</h2>
      <p>{t.legal.text1}</p>
      <p>{t.legal.text2}</p>

      <!-- Source -->
      <p class="text-sm text-text-muted mt-12">{t.source}</p>
    </div>
  </Container>
</section>
