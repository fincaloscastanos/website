---
import type { MediaTranslations } from "./media.i18n";
import type { Language } from "@/lib/i18n";
import { Image } from "astro:assets";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";
import { Icon } from "astro-icon/components";

import previewMia from "./images/previews/instagram-mia.jpg";
import previewTvCanaria1 from "./images/previews/tv-canaria-1.jpg";
import previewTvCanaria2 from "./images/previews/tv-canaria-2.jpg";
import previewBrodie from "./images/previews/youtube-brodie.jpg";
import previewGino from "./images/previews/youtube-gino.jpg";
import previewSanJorge from "./images/previews/youtube-sanjorge.jpg";
import previewRadio from "./images/previews/radio-espejo.jpg";
import imgKaffee from "./images/kaffee2.png";

import pattern02 from "@/assets/patterns/pattern-02.svg";
import pattern04 from "@/assets/patterns/pattern-04.svg";
import pattern06 from "@/assets/patterns/pattern-06.svg";
import pattern07 from "@/assets/patterns/pattern-07.svg";
import imgGeheimnis2 from "./images/das_geheimnis_von_Agaete-845x684.png";

interface Props {
  lang: Language;
  t: MediaTranslations;
}

const { lang, t } = Astro.props;

type Card = {
  image: ImageMetadata;
  icon: string;
  color?: string;
  badge: string | Record<Language, string>;
  title: Record<Language, string>;
  description: Record<Language, string>;
  href: string;
  featured?: boolean;
};

const groups: { label: Record<Language, string>; icon: string; color?: string; cards: Card[] }[] = [
  {
    label: { de: "TV & Presse", en: "TV & Press", es: "TV y prensa" },
    icon: "lucide:tv",
    cards: [
      {
        image: previewTvCanaria1,
        icon: "lucide:tv" as const,
        badge: "TV",
        featured: true,
        title: { de: "Ponte al día – Televisión Canaria", en: "Ponte al día – Televisión Canaria", es: "Ponte al día – Televisión Canaria" },
        description: {
          de: "Televisión Canaria besucht die Finca und zeigt den Alltag auf Europas Kaffeeplantage.",
          en: "Televisión Canaria visits the Finca and shows daily life on Europe's coffee plantation.",
          es: "Televisión Canaria visita la Finca y muestra la vida cotidiana en la plantación de café de Europa.",
        },
        href: "https://www.instagram.com/p/DKclzSzIFfR/",
      },
      {
        image: previewTvCanaria2,
        icon: "lucide:tv" as const,
        badge: "TV",
        title: { de: "Ponte al día – Teil 2", en: "Ponte al día – Part 2", es: "Ponte al día – Parte 2" },
        description: {
          de: "Der zweite Teil des TV-Beitrags über Kaffeeanbau und Nachhaltigkeit im Valle de Agaete.",
          en: "The second part of the TV report on coffee cultivation and sustainability in the Valle de Agaete.",
          es: "La segunda parte del reportaje televisivo sobre el cultivo de café y la sostenibilidad en el Valle de Agaete.",
        },
        href: "https://www.instagram.com/p/DKcmfMuIiPA/",
      },
      {
        image: imgKaffee,
        icon: "lucide:newspaper" as const,
        badge: { de: "Presse", en: "Press", es: "Prensa" },
        title: { de: "Wochenblatt – Seite 32", en: "Wochenblatt – Page 32", es: "Wochenblatt – Página 32" },
        description: {
          de: "Das Wochenblatt berichtet über die Kaffeeplantage im Valle de Agaete und ihre einzigartige Geschichte.",
          en: "The Wochenblatt reports on the coffee plantation in the Valle de Agaete and its unique story.",
          es: "El Wochenblatt informa sobre la plantación de café en el Valle de Agaete y su historia única.",
        },
        href: "https://www.wochenblatt.es/ausgabe/466/N45F/",
      },
      {
        image: imgGeheimnis2,
        icon: "lucide:newspaper" as const,
        badge: { de: "Presse", en: "Press", es: "Prensa" },
        title: { de: "Wochenblatt – Seite 33", en: "Wochenblatt – Page 33", es: "Wochenblatt – Página 33" },
        description: {
          de: "Fortsetzung des Artikels – von der Ernte bis zur Tasse: Kaffeeproduktion auf Gran Canaria.",
          en: "Continuation of the article – from harvest to cup: coffee production on Gran Canaria.",
          es: "Continuación del artículo – de la cosecha a la taza: producción de café en Gran Canaria.",
        },
        href: "https://www.wochenblatt.es/ausgabe/466/UVKU/",
      },
      {
        image: previewRadio,
        icon: "lucide:radio" as const,
        badge: "Radio",
        title: { de: "El Espejo Canario", en: "El Espejo Canario", es: "El Espejo Canario" },
        description: {
          de: "Canarias – der einzige Ort in Europa, an dem Kaffee angebaut wird. Ein Radiobeitrag.",
          en: "The Canary Islands – Europe's only place where coffee is grown. A radio feature.",
          es: "Canarias – el único lugar de Europa donde se produce café. Un reportaje de radio.",
        },
        href: "https://www.elespejocanario.es/secciones/canarias-unico-lugar-europeo-donde-se-produce-cafe/",
      },
    ],
  },
  {
    label: { de: "Social Media", en: "Social Media", es: "Redes sociales" },
    icon: "lucide:share-2",
    cards: [
      {
        image: previewBrodie,
        icon: "simple-icons:youtube" as const,
        color: "#FF0000",
        badge: "YouTube",
        title: { de: "@Brodie Vissers", en: "@Brodie Vissers", es: "@Brodie Vissers" },
        description: {
          de: "Ein Videoessay über Kaffeekultur und das besondere Erlebnis auf der Finca Los Castaños.",
          en: "A video essay on coffee culture and the special experience at Finca Los Castaños.",
          es: "Un videoensayo sobre la cultura del café y la experiencia especial en la Finca Los Castaños.",
        },
        href: "https://www.youtube.com/watch?v=NC4tnlYw6NM",
      },
      {
        image: previewGino,
        icon: "simple-icons:youtube" as const,
        color: "#FF0000",
        badge: "YouTube",
        title: { de: "@Gino Maccanti", en: "@Gino Maccanti", es: "@Gino Maccanti" },
        description: {
          de: "Gino Maccanti entdeckt die Geheimnisse des kanarischen Kaffees im Herzen von Gran Canaria.",
          en: "Gino Maccanti discovers the secrets of Canarian coffee in the heart of Gran Canaria.",
          es: "Gino Maccanti descubre los secretos del café canario en el corazón de Gran Canaria.",
        },
        href: "https://www.youtube.com/watch?v=QewollNMJrQ",
      },
      {
        image: previewSanJorge,
        icon: "simple-icons:youtube" as const,
        color: "#FF0000",
        badge: "YouTube",
        title: { de: "@San Jorge Café Del Bueno", en: "@San Jorge Café Del Bueno", es: "@San Jorge Café Del Bueno" },
        description: {
          de: "San Jorge Café begleitet den Weg der Kaffeebohne von der Plantage bis zur perfekten Tasse.",
          en: "San Jorge Café follows the coffee bean's journey from plantation to the perfect cup.",
          es: "San Jorge Café sigue el camino del grano de café desde la plantación hasta la taza perfecta.",
        },
        href: "https://www.youtube.com/watch?v=JLbkIs-6f8Q",
      },
      {
        image: previewMia,
        icon: "simple-icons:instagram" as const,
        color: "#E4405F",
        badge: "Instagram",
        title: { de: "@mia.inacio", en: "@mia.inacio", es: "@mia.inacio" },
        description: {
          de: "Ein persönlicher Einblick in die Finca Los Castaños – erzählt durch die Linse einer Reisenden.",
          en: "A personal glimpse of Finca Los Castaños – told through the lens of a traveller.",
          es: "Una mirada personal a la Finca Los Castaños – contada a través de la lente de una viajera.",
        },
        href: "https://www.instagram.com/p/DT-my9yDI0l/",
      },
    ],
  },
];
---

<PageHero title={t.hero.title} subtitle={t.hero.subtitle} />

<!-- Intro + TV & Press -->
<section class="pt-8 md:pt-12 pb-16 md:pb-24 bg-background relative overflow-hidden">
  <img src={pattern04.src} alt="" class="absolute top-4 md:-top-4 right-0 md:-right-8 w-40 md:w-56 opacity-[0.12] rotate-12 pointer-events-none select-none" />

  <img src={pattern07.src} alt="" class="absolute top-1/2 right-0 md:-right-4 w-20 md:w-32 opacity-[0.09] rotate-45 pointer-events-none select-none" />
  <img src={pattern06.src} alt="" class="absolute bottom-1/4 right-0 md:right-auto md:-left-8 w-36 md:w-48 opacity-[0.08] rotate-[-20deg] pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto text-center mb-12" data-animate>
      <p class="text-text-muted leading-relaxed">
        {t.intro.text}
      </p>
    </div>
    {groups.slice(0, 1).map((group) => {
      const featuredCard = group.cards.find((c) => c.featured);
      const regularCards = group.cards.filter((c) => !c.featured);
      return (
        <div>
          {/* Group Header */}
          <div class="flex items-center gap-4 mb-8" data-animate>
            <div class="w-10 h-10 bg-primary/10 flex items-center justify-center shrink-0">
              <Icon name={group.icon} class="w-5 h-5 text-primary" />
            </div>
            <h2 class="text-lg md:text-xl font-sans uppercase tracking-wider font-light">
              {group.label[lang]}
            </h2>
            <div class="flex-1 h-px bg-border" />
          </div>

          {/* Featured Card */}
          {featuredCard && (
            <a
              href={featuredCard.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group grid md:grid-cols-2 bg-background border border-border/50 overflow-hidden hover:border-primary/30 hover:shadow-xl transition-all duration-300 mb-6"
              data-animate
            >
              <div class="relative overflow-hidden aspect-video md:aspect-auto md:min-h-[20rem]">
                <Image
                  src={featuredCard.image}
                  alt={featuredCard.title[lang]}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  widths={[500, 800, 1200]}
                  sizes="(max-width: 768px) 100vw, 50vw"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 bg-white/90 backdrop-blur-sm text-xs font-medium uppercase tracking-wider text-text-heading px-3 py-1">
                  <Icon name={featuredCard.icon} class="w-3.5 h-3.5" style={featuredCard.color ? `color: ${featuredCard.color}` : undefined} />
                  {typeof featuredCard.badge === "string" ? featuredCard.badge : featuredCard.badge[lang]}
                </span>
              </div>
              <div class="p-8 md:p-10 flex flex-col justify-center">
                <h3 class="text-lg md:text-xl font-medium text-text-heading group-hover:text-accent transition-colors duration-300 mb-3">
                  {featuredCard.title[lang]}
                </h3>
                <p class="text-text-muted leading-relaxed mb-6">
                  {featuredCard.description[lang]}
                </p>
                <span class="inline-flex items-center gap-2 text-sm font-medium text-accent">
                  <Icon name="lucide:external-link" class="w-4 h-4" />
                  {lang === "de" ? "Beitrag ansehen" : lang === "en" ? "Watch report" : "Ver reportaje"}
                </span>
              </div>
            </a>
          )}

          {/* Regular Cards */}
          <div class={`grid gap-6 ${regularCards.length <= 2 ? "md:grid-cols-2" : "md:grid-cols-2 lg:grid-cols-4"}`}>
            {regularCards.map((card) => (
              <a
                href={card.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-background border border-border/50 overflow-hidden hover:border-primary/30 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col"
                data-animate
              >
                <div class="relative overflow-hidden aspect-video">
                  <Image
                    src={card.image}
                    alt={card.title[lang]}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    widths={[300, 500]}
                    sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 25vw"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                  <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 bg-white/90 backdrop-blur-sm text-xs font-medium uppercase tracking-wider text-text-heading px-3 py-1">
                    <Icon name={card.icon} class="w-3.5 h-3.5" style={card.color ? `color: ${card.color}` : undefined} />
                    {typeof card.badge === "string" ? card.badge : card.badge[lang]}
                  </span>
                </div>
                <div class="p-5 flex flex-col flex-1">
                  <h3 class="text-base font-medium text-text-heading group-hover:text-accent transition-colors duration-300 mb-2">
                    {card.title[lang]}
                  </h3>
                  <p class="text-sm text-text-muted leading-relaxed flex-1">
                    {card.description[lang]}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </Container>
</section>

<!-- Social Media -->
<section class="pb-16 md:pb-24 bg-background">
  <Container>
    {groups.slice(1).map((group) => {
      const featuredCard = group.cards.find((c) => c.featured);
      const regularCards = group.cards.filter((c) => !c.featured);
      return (
        <div>
          {/* Group Header */}
          <div class="flex items-center gap-4 mb-8" data-animate>
            <div class="w-10 h-10 bg-primary/10 flex items-center justify-center shrink-0">
              <Icon name={group.icon} class="w-5 h-5 text-primary" />
            </div>
            <h2 class="text-lg md:text-xl font-sans uppercase tracking-wider font-light">
              {group.label[lang]}
            </h2>
            <div class="flex-1 h-px bg-border" />
          </div>

          {/* Featured Card */}
          {featuredCard && (
            <a
              href={featuredCard.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group grid md:grid-cols-2 bg-background border border-border/50 overflow-hidden hover:border-primary/30 hover:shadow-xl transition-all duration-300 mb-6"
              data-animate
            >
              <div class="relative overflow-hidden aspect-video md:aspect-auto md:min-h-[20rem]">
                <Image
                  src={featuredCard.image}
                  alt={featuredCard.title[lang]}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  widths={[500, 800, 1200]}
                  sizes="(max-width: 768px) 100vw, 50vw"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 bg-white/90 backdrop-blur-sm text-xs font-medium uppercase tracking-wider text-text-heading px-3 py-1">
                  <Icon name={featuredCard.icon} class="w-3.5 h-3.5" style={featuredCard.color ? `color: ${featuredCard.color}` : undefined} />
                  {typeof featuredCard.badge === "string" ? featuredCard.badge : featuredCard.badge[lang]}
                </span>
              </div>
              <div class="p-8 md:p-10 flex flex-col justify-center">
                <h3 class="text-lg md:text-xl font-medium text-text-heading group-hover:text-accent transition-colors duration-300 mb-3">
                  {featuredCard.title[lang]}
                </h3>
                <p class="text-text-muted leading-relaxed mb-6">
                  {featuredCard.description[lang]}
                </p>
                <span class="inline-flex items-center gap-2 text-sm font-medium text-accent">
                  <Icon name="lucide:external-link" class="w-4 h-4" />
                  {lang === "de" ? "Beitrag ansehen" : lang === "en" ? "Watch report" : "Ver reportaje"}
                </span>
              </div>
            </a>
          )}

          {/* Regular Cards */}
          <div class={`grid gap-6 ${regularCards.length <= 2 ? "md:grid-cols-2" : "md:grid-cols-2 lg:grid-cols-4"}`}>
            {regularCards.map((card) => (
              <a
                href={card.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-background border border-border/50 overflow-hidden hover:border-primary/30 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col"
                data-animate
              >
                <div class="relative overflow-hidden aspect-video">
                  <Image
                    src={card.image}
                    alt={card.title[lang]}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    widths={[300, 500]}
                    sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 25vw"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                  <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 bg-white/90 backdrop-blur-sm text-xs font-medium uppercase tracking-wider text-text-heading px-3 py-1">
                    <Icon name={card.icon} class="w-3.5 h-3.5" style={card.color ? `color: ${card.color}` : undefined} />
                    {typeof card.badge === "string" ? card.badge : card.badge[lang]}
                  </span>
                </div>
                <div class="p-5 flex flex-col flex-1">
                  <h3 class="text-base font-medium text-text-heading group-hover:text-accent transition-colors duration-300 mb-2">
                    {card.title[lang]}
                  </h3>
                  <p class="text-sm text-text-muted leading-relaxed flex-1">
                    {card.description[lang]}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </Container>
</section>
