---
import type { HomeTranslations } from "./home.i18n";
import type { Language } from "@/lib/i18n";
import { Image } from "astro:assets";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";
import PrivacyMap from "@/components/ui/PrivacyMap.astro";
import { Icon } from "astro-icon/components";
import { siteData } from "@/data/site";
import { getTranslatedPath } from "@/lib/registry";

import cardEvents from "@/assets/events/tent-interior.jpg";
import cardTours from "./cafe-tour.jpg";
import cardAccommodation from "@/assets/relax/cabana/04-bathroom.jpg";
import aboutImg from "@/assets/home/about.jpg";
import heroIllustration from "@/assets/home/hero-illustration.webp";
import productsImg from "@/assets/home/products.jpg";
import productsDetailImg from "@/assets/home/coffee-plant.png";
import tourImg from "@/assets/home/tour.jpg";
import aboutDetailImg from "@/assets/home/events-banner.png";
import sustainabilityPanorama from "@/assets/home/card-events.jpeg";
import sustainabilityDetail from "@/assets/home/card-accommodation.jpeg";

import pattern02 from "@/assets/patterns/pattern-02.svg";
import pattern04 from "@/assets/patterns/pattern-04.svg";
import pattern06 from "@/assets/patterns/pattern-06.svg";
import pattern07 from "@/assets/patterns/pattern-07.svg";

import gallery01 from "@/assets/home/gallery/01.jpg";
import gallery02 from "@/assets/home/gallery/02.jpg";
import gallery03 from "@/assets/home/gallery/03.jpg";
import gallery04 from "@/assets/home/gallery/04.jpg";
import gallery05 from "@/assets/home/gallery/05.jpg";
import gallery06 from "@/assets/home/gallery/06.jpg";
import gallery07 from "@/assets/home/gallery/07.jpg";
import gallery08 from "@/assets/home/gallery/08.jpg";
import gallery09 from "@/assets/home/gallery/09.jpg";
import gallery10 from "@/assets/home/gallery/10.jpg";
import gallery11 from "@/assets/home/gallery/11.jpg";
import gallery12 from "@/assets/home/gallery/12.jpg";

interface Props {
  lang: Language;
  t: HomeTranslations;
}

const { lang, t } = Astro.props;

const eventsHref = getTranslatedPath("events", lang);
const experienceHref = getTranslatedPath("experience", lang);
const relaxHref = getTranslatedPath("relax", lang);
const coffeeTourHref = getTranslatedPath("coffee-tour", lang);
const bookTourHref = getTranslatedPath("book-tour", lang);

const galleryImages = [
  gallery01,
  gallery02,
  gallery03,
  gallery04,
  gallery05,
  gallery06,
  gallery07,
  gallery08,
  gallery09,
  gallery10,
  gallery11,
  gallery12,
];
---

<PageHero title={t.hero.title} subtitle={t.hero.subtitle} />

<!-- Quick-Jump Cards -->
<section class="pb-16 md:pb-24 bg-surface">
  <Container>
    <div class="grid md:grid-cols-3 gap-4 md:gap-6">
      <!-- Card: Tours (primary) — mobile 1st, desktop 2nd -->
      <a
        href={bookTourHref}
        class="group bg-secondary shadow-xl overflow-hidden flex flex-col hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 md:order-2"
      >
        <div class="relative overflow-hidden">
          <Image
            src={cardTours}
            alt={t.cards.tours.title}
            class="w-full h-40 md:h-48 object-cover object-top transition-transform duration-500 group-hover:scale-105"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 33vw"
          />
          <p
            class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent px-5 pt-8 pb-3 font-serif text-white text-xl md:text-2xl drop-shadow-[0_1px_4px_rgba(0,0,0,0.7)]"
          >
            {t.cards.tours.subtitle}
          </p>
        </div>
        <div class="p-5 flex flex-col flex-1 text-white">
          <p class="text-white/90 text-sm leading-relaxed mb-5 flex-1">
            {t.cards.tours.description}
          </p>
          <span
            class="inline-flex items-center justify-center gap-2 w-full py-2.5 bg-white/20 text-white text-sm font-bold uppercase tracking-wider group-hover:bg-white/30 transition-colors duration-300"
          >
            {t.cards.tours.cta}
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </span>
        </div>
      </a>

      <!-- Card: Accommodation — mobile 2nd, desktop 3rd -->
      <a
        href={relaxHref}
        class="group bg-background shadow-xl overflow-hidden border border-border/50 flex flex-col hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 md:order-3"
      >
        <div class="relative overflow-hidden">
          <Image
            src={cardAccommodation}
            alt={t.cards.accommodation.title}
            class="w-full h-40 md:h-48 object-cover transition-transform duration-500 group-hover:scale-105"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 33vw"
          />
          <p
            class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent px-5 pt-8 pb-3 font-serif text-white text-xl md:text-2xl drop-shadow-[0_1px_4px_rgba(0,0,0,0.7)]"
          >
            {t.cards.accommodation.subtitle}
          </p>
        </div>
        <div class="p-5 flex flex-col flex-1">
          <p class="text-text-muted text-sm leading-relaxed mb-5 flex-1">
            {t.cards.accommodation.description}
          </p>
          <span
            class="inline-flex items-center justify-center gap-2 w-full py-2.5 bg-primary text-white text-sm font-bold uppercase tracking-wider group-hover:bg-primary-dark transition-colors duration-300"
          >
            {t.cards.accommodation.cta}
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </span>
        </div>
      </a>

      <!-- Card: Events — mobile 3rd, desktop 1st -->
      <a
        href={eventsHref}
        class="group bg-background shadow-xl overflow-hidden border border-border/50 flex flex-col hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 md:order-1"
      >
        <div class="relative overflow-hidden">
          <Image
            src={cardEvents}
            alt={t.cards.events.title}
            class="w-full h-40 md:h-48 object-cover transition-transform duration-500 group-hover:scale-105"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 33vw"
          />
          <p
            class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent px-5 pt-8 pb-3 font-serif text-white text-xl md:text-2xl drop-shadow-[0_1px_4px_rgba(0,0,0,0.7)]"
          >
            {t.cards.events.subtitle}
          </p>
        </div>
        <div class="p-5 flex flex-col flex-1">
          <p class="text-text-muted text-sm leading-relaxed mb-5 flex-1">
            {t.cards.events.description}
          </p>
          <span
            class="inline-flex items-center justify-center gap-2 w-full py-2.5 bg-primary text-white text-sm font-bold uppercase tracking-wider group-hover:bg-primary-dark transition-colors duration-300"
          >
            {t.cards.events.cta}
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </span>
        </div>
      </a>
    </div>
  </Container>
</section>

<!-- Illustration & Quote -->
<section class="pt-8 md:pt-16 pb-16 md:pb-24 bg-background">
  <Container>
    <div class="flex justify-center" data-animate="fade">
      <Image
        src={heroIllustration}
        alt="Finca Los Castaños Illustration"
        class="w-full max-w-md h-auto"
        widths={[400, 600, 800]}
        sizes="(max-width: 768px) 100vw, 600px"
      />
    </div>

    <!-- Quote -->
    <blockquote class="text-center mt-12" data-animate="fade">
      <p
        class="text-base md:text-lg lg:text-xl font-sans uppercase tracking-[0.15em] text-brown-dark leading-tight font-light"
      >
        &laquo;{t.about.quote}&raquo;
      </p>
    </blockquote>
  </Container>
</section>

<!-- Video -->
<section class="w-full">
  <video
    autoplay
    muted
    playsinline
    preload="auto"
    class="w-full h-[40vh] md:h-[50vh] object-cover block"
  >
    <source src="/hero.mp4" type="video/mp4" />
  </video>
</section>
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "VideoObject",
  name: lang === "de" ? "Finca Los Castaños – Kaffeeplantage im Valle de Agaete" : lang === "en" ? "Finca Los Castaños – Coffee Plantation in Valle de Agaete" : "Finca Los Castaños – Plantación de café en el Valle de Agaete",
  description: lang === "de" ? "Eindrücke unserer Kaffeeplantage im Valle de Agaete, Gran Canaria – Europas einzige Kaffeeanbauregion." : lang === "en" ? "Impressions of our coffee plantation in the Valle de Agaete, Gran Canaria – Europe's only coffee-growing region." : "Imágenes de nuestra plantación de café en el Valle de Agaete, Gran Canaria – la única región cafetera de Europa.",
  contentUrl: "https://fincaloscastanos.com/hero.mp4",
  thumbnailUrl: "https://fincaloscastanos.com/og-default.png",
  uploadDate: "2025-01-01",
})} />

<!-- About Section -->
<section class="py-16 md:py-24 bg-surface relative overflow-hidden">
  <img
    src={pattern04.src}
    alt=""
    class="absolute top-4 md:-top-4 right-0 md:-right-8 w-40 md:w-56 opacity-[0.12] rotate-12 pointer-events-none select-none"
  />
  <img
    src={pattern02.src}
    alt=""
    class="absolute bottom-4 md:-bottom-6 right-0 md:right-auto md:-left-6 w-24 md:w-36 opacity-[0.10] -rotate-12 pointer-events-none select-none"
  />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Images -->
      <div class="relative" data-animate>
        <div class="overflow-hidden shadow-xl border border-border">
          <Image
            src={aboutImg}
            alt="Finca Los Castaños Plantage"
            class="w-full h-auto object-cover"
            widths={[500, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
        <div
          class="overflow-hidden shadow-2xl w-2/3 mr-auto -mt-16 relative z-10 border border-border"
        >
          <Image
            src={aboutDetailImg}
            alt="Finca Los Castaños Team"
            class="w-full h-auto object-cover"
            widths={[300, 500]}
            sizes="(max-width: 768px) 66vw, 33vw"
          />
        </div>
      </div>

      <!-- Text -->
      <div data-animate data-animate-delay="2">
        <h2
          class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
        >
          {t.about.title}
        </h2>
        <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
          {t.about.subtitle}
        </p>
        <p class="text-text-muted leading-relaxed mb-8">
          {t.about.description}
        </p>
        <a
          href={experienceHref}
          class="inline-flex items-center gap-2 bg-primary text-white font-medium py-3 px-8 rounded-none hover:bg-primary-dark transition-colors duration-300 shadow-lg"
        >
          {t.about.cta}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </Container>
</section>

<!-- Products Section -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img
    src={pattern07.src}
    alt=""
    class="absolute top-8 right-0 md:right-auto md:-left-6 w-28 md:w-40 opacity-[0.10] rotate-6 pointer-events-none select-none"
  />
  <img
    src={pattern06.src}
    alt=""
    class="absolute bottom-4 md:-bottom-16 right-0 md:-right-10 w-36 md:w-52 opacity-[0.09] -rotate-6 pointer-events-none select-none"
  />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div data-animate>
        <h2
          class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
        >
          {t.products.title}
        </h2>
        <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
          {t.products.subtitle}
        </p>
        <p class="text-text-muted leading-relaxed mb-8">
          {t.products.description}
        </p>

        <!-- Stats -->
        <div class="flex gap-8 mb-8">
          <div class="text-center">
            <span
              class="block text-4xl md:text-5xl font-serif font-bold text-secondary"
              >2</span
            >
            <span class="text-base text-text-muted"
              >{t.products.stat1Label}</span
            >
          </div>
          <div class="text-center">
            <span
              class="block text-4xl md:text-5xl font-serif font-bold text-secondary"
              >4</span
            >
            <span class="text-base text-text-muted"
              >{t.products.stat2Label}</span
            >
          </div>
        </div>

        <a
          href={experienceHref}
          class="inline-flex items-center gap-2 bg-primary text-white font-medium py-3 px-8 rounded-none hover:bg-primary-dark transition-colors duration-300 shadow-lg"
        >
          {t.products.cta}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>

      <!-- Images -->
      <div class="relative" data-animate data-animate-delay="2">
        <div class="overflow-hidden shadow-xl border border-border">
          <Image
            src={productsImg}
            alt={t.products.title}
            class="w-full h-auto object-cover"
            widths={[500, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
        <div
          class="overflow-hidden shadow-2xl w-2/3 ml-auto -mt-16 relative z-10 border border-border"
        >
          <Image
            src={productsDetailImg}
            alt={t.products.title}
            class="w-full h-auto object-cover"
            widths={[300, 500]}
            sizes="(max-width: 768px) 66vw, 33vw"
          />
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Tour Booking Section -->
<section class="py-16 md:py-24 bg-accent relative overflow-hidden">
  <div
    class="absolute inset-0 bg-repeat opacity-10"
    style={`background-image: url(${pattern06.src})`}
  >
  </div>
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image -->
      <div class="overflow-hidden shadow-xl" data-animate>
        <Image
          src={tourImg}
          alt={t.tour.title}
          class="w-full h-auto object-cover"
          widths={[500, 800]}
          sizes="(max-width: 768px) 100vw, 50vw"
        />
      </div>

      <!-- Content -->
      <div data-animate data-animate-delay="2">
        <h2
          class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light text-text-heading"
        >
          {t.tour.title}
        </h2>
        <p class="font-serif text-white text-2xl md:text-3xl mb-3">
          {t.tour.subtitle}
        </p>
        <p class="text-text leading-relaxed mb-8">{t.tour.description}</p>

        <div
          class="bg-white/50 backdrop-blur-sm rounded-none p-6 mb-8 border border-border/60"
        >
          <h3 class="text-lg font-serif text-text-heading mb-3">
            {t.tour.hoursTitle}
          </h3>
          <p class="text-text text-base">
            {
              t.tour.weekdays
                .replace("{start}", siteData.hours.weekdays.start)
                .replace("{end}", siteData.hours.weekdays.end)
            }
          </p>
          <p class="text-text text-base">
            {
              t.tour.weekends
                .replace("{start}", siteData.hours.weekends.start)
                .replace("{end}", siteData.hours.weekends.end)
            }
          </p>
        </div>

        <a
          href={coffeeTourHref}
          class="inline-flex items-center gap-2 bg-secondary text-text-heading font-bold py-3 px-8 rounded-none hover:bg-secondary/80 transition-colors duration-300 shadow-lg"
        >
          {t.tour.cta}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </Container>
</section>

<!-- Sustainability Section -->
<section class="py-16 md:py-24 bg-surface relative overflow-hidden">
  <img
    src={pattern02.src}
    alt=""
    class="absolute top-10 right-0 md:-right-4 w-20 md:w-32 opacity-[0.12] rotate-45 pointer-events-none select-none"
  />
  <img
    src={pattern04.src}
    alt=""
    class="absolute bottom-4 md:-bottom-8 right-0 md:right-auto md:-left-8 w-36 md:w-48 opacity-[0.10] rotate-[-20deg] pointer-events-none select-none"
  />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div data-animate>
        <h2
          class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
        >
          {t.sustainability.title}
        </h2>
        <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
          {t.sustainability.subtitle}
        </p>
        <p class="text-text-muted leading-relaxed">
          {t.sustainability.description}
        </p>
      </div>

      <!-- Images -->
      <div class="relative" data-animate data-animate-delay="2">
        <div class="overflow-hidden shadow-xl border border-border">
          <Image
            src={sustainabilityPanorama}
            alt={t.sustainability.title}
            class="w-full h-auto object-cover"
            widths={[500, 800]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
        <div
          class="overflow-hidden shadow-2xl w-2/3 ml-auto -mt-16 relative z-10 border border-border"
        >
          <Image
            src={sustainabilityDetail}
            alt={t.sustainability.title}
            class="w-full h-auto object-cover"
            widths={[300, 500]}
            sizes="(max-width: 768px) 66vw, 33vw"
          />
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Gallery Section -->
<section class="py-16 md:py-24 bg-background">
  <Container>
    <h2
      class="text-3xl md:text-4xl lg:text-5xl text-center mb-12"
      data-animate="fade"
    >
      {t.gallery.title}
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
      {
        galleryImages.map((img, i) => (
          <div
            class="overflow-hidden group aspect-[5/4]"
            data-animate="fade"
            data-animate-delay={`${i + 1}`}
          >
            <Image
              src={img}
              alt={`Finca Los Castaños ${i + 1}`}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              widths={[300, 500]}
              sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
            />
          </div>
        ))
      }
    </div>
  </Container>
</section>

<!-- Contact Section -->
<section
  id="kontakt"
  class="py-16 md:py-24 bg-surface relative overflow-hidden"
>
  <img
    src={pattern07.src}
    alt=""
    class="absolute top-4 md:-top-4 right-0 md:right-auto md:-left-6 w-28 md:w-36 opacity-[0.10] rotate-[-15deg] pointer-events-none select-none"
  />
  <img
    src={pattern04.src}
    alt=""
    class="absolute bottom-12 right-0 md:-right-10 w-40 md:w-56 opacity-[0.09] rotate-[25deg] pointer-events-none select-none"
  />
  <Container class="relative z-10">
    <div class="text-center mb-12" data-animate>
      <h2
        class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light"
      >
        {t.contact.title}
      </h2>
      <p class="font-serif text-accent text-2xl md:text-3xl mb-3">
        {t.contact.subtitle}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Map -->
      <div
        class="overflow-hidden shadow-lg h-80 md:h-full md:min-h-[28rem]"
        data-animate
      >
        <PrivacyMap
          url={siteData.contact.googleMapsEmbed}
          loadMap={t.contact.map.loadMap}
          accept={t.contact.map.accept}
          showMap={t.contact.map.showMap}
        />
      </div>

      <!-- Contact Info -->
      <div class="flex flex-col gap-4" data-animate data-animate-delay="2">
        <!-- Address -->
        <a
          href={siteData.contact.googleMaps}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-4 p-5 bg-background rounded-none border border-border/50 hover:border-primary/30 hover:shadow-md transition-all"
        >
          <div
            class="w-10 h-10 rounded-none bg-primary/10 flex items-center justify-center shrink-0"
          >
            <Icon name="lucide:map-pin" class="w-5 h-5 text-primary" />
          </div>
          <div>
            <span
              class="block text-xs uppercase tracking-widest text-accent font-medium mb-1"
              >{t.contact.info.addressLabel}</span
            >
            <span
              class="text-base text-text-muted group-hover:text-text transition-colors leading-relaxed"
              >{siteData.contact.address}</span
            >
          </div>
        </a>

        <!-- Email -->
        <a
          href={`mailto:${siteData.contact.email}`}
          class="group flex items-start gap-4 p-5 bg-background rounded-none border border-border/50 hover:border-primary/30 hover:shadow-md transition-all"
        >
          <div
            class="w-10 h-10 rounded-none bg-primary/10 flex items-center justify-center shrink-0"
          >
            <Icon name="lucide:mail" class="w-5 h-5 text-primary" />
          </div>
          <div>
            <span
              class="block text-xs uppercase tracking-widest text-accent font-medium mb-1"
              >{t.contact.info.emailLabel}</span
            >
            <span
              class="text-base text-text-muted group-hover:text-text transition-colors"
              >{siteData.contact.email}</span
            >
          </div>
        </a>

        <!-- Phone -->
        <div class="p-5 bg-background rounded-none border border-border/50">
          <div class="flex items-center gap-4 mb-3">
            <div
              class="w-10 h-10 rounded-none bg-primary/10 flex items-center justify-center shrink-0"
            >
              <Icon name="lucide:phone" class="w-5 h-5 text-primary" />
            </div>
            <span
              class="text-xs uppercase tracking-widest text-accent font-medium"
              >Telefon</span
            >
          </div>
          <div class="space-y-2 pl-14">
            <a
              href={`tel:${siteData.contact.phone.replaceAll(" ", "")}`}
              class="flex justify-between items-center text-base text-text-muted hover:text-text transition-colors"
            >
              <span class="text-sm text-text-muted/70"
                >{t.contact.info.toursLabel}</span
              >
              <span>{siteData.contact.phone}</span>
            </a>
            <a
              href={`tel:${siteData.contact.phoneEvents.replaceAll(" ", "")}`}
              class="flex justify-between items-center text-base text-text-muted hover:text-text transition-colors"
            >
              <span class="text-sm text-text-muted/70"
                >{t.contact.info.eventsLabel}</span
              >
              <span>{siteData.contact.phoneEvents}</span>
            </a>
          </div>
        </div>

        <!-- Opening Hours -->
        <div class="p-5 bg-background rounded-none border border-border/50">
          <div class="flex items-center gap-4 mb-3">
            <div
              class="w-10 h-10 rounded-none bg-primary/10 flex items-center justify-center shrink-0"
            >
              <Icon name="lucide:clock" class="w-5 h-5 text-primary" />
            </div>
            <span
              class="text-xs uppercase tracking-widest text-accent font-medium"
              >{t.contact.info.hoursLabel}</span
            >
          </div>
          <div class="space-y-2 pl-14">
            <p class="text-base text-text-muted">
              {
                t.contact.info.hoursWeekdays
                  .replace("{start}", siteData.hours.weekdays.start)
                  .replace("{end}", siteData.hours.weekdays.end)
              }
            </p>
            <p class="text-base text-text-muted">
              {
                t.contact.info.hoursWeekends
                  .replace("{start}", siteData.hours.weekends.start)
                  .replace("{end}", siteData.hours.weekends.end)
              }
            </p>
          </div>
        </div>

        <!-- WhatsApp CTA -->
        <a
          href={`https://wa.me/${siteData.contact.whatsapp.replaceAll(" ", "").replace("+", "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 bg-primary text-white font-medium py-3.5 px-8 rounded-none hover:bg-primary-dark transition-colors text-base shadow-lg"
        >
          <Icon name="simple-icons:whatsapp" class="w-5 h-5" />
          WhatsApp
        </a>
      </div>
    </div>
  </Container>
</section>
