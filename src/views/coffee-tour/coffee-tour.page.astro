---
import type { CoffeeTourTranslations } from "./coffee-tour.i18n";
import type { Language } from "@/lib/i18n";
import { Image } from "astro:assets";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";
import { Icon } from "astro-icon/components";
import { siteData } from "@/data/site";
import { getTranslatedPath } from "@/lib/registry";

import guideImg from "@/assets/coffee-tour/guide.jpg";
import tastingImg from "@/assets/coffee-tour/tasting.jpg";
import plantationImg from "@/assets/coffee-tour/plantation.jpg";
import heroDetailImg from "@/assets/coffee-tour/hero.jpg";

import pattern02 from "@/assets/patterns/pattern-02.svg";
import pattern04 from "@/assets/patterns/pattern-04.svg";
import pattern07 from "@/assets/patterns/pattern-07.svg";

interface Props {
  lang: Language;
  t: CoffeeTourTranslations;
}

const { lang, t } = Astro.props;

const { coffeeTour } = siteData;
const bookTourHref = getTranslatedPath("book-tour", lang);
const formatPrice = (price: number) =>
  price % 1 === 0
    ? `${price},00 EUR`
    : `${price.toFixed(2).replace(".", ",")} EUR`;
---

<PageHero title={t.hero.title} subtitle={t.hero.subtitle} ctaLabel={t.hero.cta} ctaHref={bookTourHref} />

<!-- Intro -->
<section class="py-16 md:py-24 bg-background relative overflow-hidden">
  <img src={pattern07.src} alt="" class="absolute top-4 md:-top-4 right-4 md:-right-8 w-28 md:w-40 opacity-[0.10] rotate-12 pointer-events-none select-none" />
  <img src={pattern02.src} alt="" class="absolute bottom-4 md:-bottom-6 left-4 md:-left-6 w-20 md:w-32 opacity-[0.10] -rotate-12 pointer-events-none select-none" />
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div class="space-y-5" data-animate>
        <p class="text-text-muted leading-relaxed">{t.intro.p1}</p>
        <p class="text-text-muted leading-relaxed">{t.intro.p2}</p>
        <p class="text-text-muted leading-relaxed">{t.intro.p3}</p>
        <p class="text-text-muted leading-relaxed">{t.intro.p4}</p>
      </div>

      <!-- Images -->
      <div class="relative max-w-sm md:max-w-md mx-auto" data-animate data-animate-delay="2">
        <div class="overflow-hidden shadow-xl">
          <Image
            src={guideImg}
            alt="Plantage"
            class="w-full h-auto object-cover"
            widths={[300, 500, 800]}
            sizes="(max-width: 768px) 80vw, 28vw"
          />
        </div>
        <div class="overflow-hidden shadow-2xl w-2/3 mr-auto -mt-16 relative z-10 border border-border">
          <Image
            src={tastingImg}
            alt="Kaffeeverkostung"
            class="w-full h-auto object-cover"
            widths={[200, 300]}
            sizes="(max-width: 768px) 50vw, 18vw"
          />
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Pricing -->
<section class="py-16 md:py-24 bg-accent relative overflow-hidden">
  <div
    class="absolute inset-0 bg-repeat opacity-10" style={`background-image: url(${pattern04.src})`}
  >
  </div>
  <Container class="relative z-10">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image -->
      <div class="relative order-2 md:order-1" data-animate>
        <div class="overflow-hidden shadow-xl">
          <Image
            src={plantationImg}
            alt="Kaffeeplantage"
            class="w-full h-auto object-cover"
            widths={[500, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
        <div class="overflow-hidden shadow-2xl w-2/3 ml-auto -mt-16 relative z-10 border border-border">
          <Image
            src={heroDetailImg}
            alt="Kaffeetour Detail"
            class="w-full h-auto object-cover"
            widths={[300, 500]}
            sizes="(max-width: 768px) 66vw, 33vw"
          />
        </div>
      </div>

      <!-- Content -->
      <div class="order-1 md:order-2" data-animate data-animate-delay="2">
        <h2
          class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-light text-text-heading"
        >
          {t.pricing.title}
        </h2>
        <p class="font-serif text-white text-2xl md:text-3xl mb-3">
          {t.pricing.subtitle}
        </p>

        <!-- Preise -->
        <div class="space-y-3 mb-10">
          <div
            class="flex items-center justify-between bg-white/50 backdrop-blur-sm rounded-none p-4 border border-border/60"
          >
            <div class="flex items-center gap-3">
              <Icon name="lucide:user" class="w-5 h-5 text-text-heading" />
              <span class="text-text">{t.pricing.adults}</span>
            </div>
            <span class="text-xl font-serif font-bold text-text-heading"
              >{formatPrice(coffeeTour.adults)}</span
            >
          </div>
          <div
            class="flex items-center justify-between bg-white/50 backdrop-blur-sm rounded-none p-4 border border-border/60"
          >
            <div class="flex items-center gap-3">
              <Icon name="lucide:baby" class="w-5 h-5 text-text-heading" />
              <span class="text-text">{t.pricing.children}</span>
            </div>
            <span class="text-xl font-serif font-bold text-text-heading"
              >{formatPrice(coffeeTour.children)}</span
            >
          </div>
          <div
            class="flex items-center justify-between bg-white/50 backdrop-blur-sm rounded-none p-4 border border-border/60"
          >
            <div class="flex items-center gap-3">
              <Icon name="lucide:heart" class="w-5 h-5 text-text-heading" />
              <span class="text-text"
                >{
                  t.pricing.infants.replace(
                    "{age}",
                    String(coffeeTour.infantsMaxAge),
                  )
                }</span
              >
            </div>
            <span class="text-xl font-serif font-bold text-text-heading"
              >{t.pricing.infantsFree}</span
            >
          </div>
        </div>

        <!-- Infos -->
        <div class="space-y-3 mb-10">
          <div class="flex items-center gap-3 bg-white/50 backdrop-blur-sm rounded-none p-4 border border-border/60">
            <Icon name="lucide:ticket-percent" class="w-5 h-5 text-text-heading shrink-0" />
            <p class="text-sm text-text-heading leading-relaxed font-medium">
              {
                t.pricing.onlineDiscount.replace(
                  "{price}",
                  formatPrice(coffeeTour.adultsOnline),
                )
              }
            </p>
          </div>
          <div class="flex items-center gap-3 bg-white/50 backdrop-blur-sm rounded-none p-4 border border-border/60">
            <Icon name="lucide:clock" class="w-5 h-5 text-text-heading shrink-0" />
            <p class="text-sm text-text leading-relaxed">
              {
                t.pricing.duration.replace(
                  "{minutes}",
                  String(coffeeTour.durationMinutes),
                )
              }
            </p>
          </div>
        </div>

        <a
          href={bookTourHref}
          class="inline-flex items-center gap-2 bg-white text-text-heading font-bold py-3 px-8 rounded-none hover:bg-white/80 transition-colors duration-300 shadow-lg"
        >
          {t.pricing.cta}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </Container>
</section>
