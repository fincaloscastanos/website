---
import type { BookTourTranslations } from "./book-tour.i18n";
import type { Language } from "@/lib/i18n";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";
import { siteData } from "@/data/site";


interface Props {
  lang: Language;
  t: BookTourTranslations;
}

const { lang, t } = Astro.props;
const { channelId, experienceId } = siteData.coffeeTour.bokun;
const widgetUrl = `https://widgets.bokun.io/online-sales/${channelId}/experience/${experienceId}?partialView=1`;
---

<PageHero title={t.hero.title} subtitle={t.hero.subtitle} />

<!-- Bokun Widget -->
<section class="py-16 md:py-24 bg-background">
  <Container>
    <div class="max-w-7xl mx-auto">
        <div
          class="bg-surface rounded-none border border-border/50 p-4 min-h-[600px]"
        >
          <div class="bokunWidget" data-src={widgetUrl}></div>
        </div>
<script is:inline src="https://widgets.bokun.io/assets/javascripts/apps/build/BokunWidgetsLoader.js"></script>
    </div>
  </Container>
</section>
