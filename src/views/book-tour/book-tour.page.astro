---
import type { BookTourTranslations } from "./book-tour.i18n";
import type { Language } from "@/lib/i18n";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";
import { siteData } from "@/data/site";

interface Props {
  lang: Language;
  t: BookTourTranslations;
}

const { lang, t } = Astro.props;
const { shortname, itemId, flow } = siteData.coffeeTour.fareharbor;
const calendarSrc = `https://fareharbor.com/embeds/script/calendar/${shortname}/items/${itemId}/?fallback=simple&full-items=yes&flow=${flow}`;
---

<PageHero title={t.hero.title} subtitle={t.hero.subtitle} />

<!-- FareHarbor Calendar Widget -->
<section class="py-16 md:py-24 bg-background">
  <Container>
    <div class="max-w-7xl mx-auto">
      <div
        class="bg-surface rounded-none border border-border/50 p-4 min-h-[600px]"
      >
        <!-- FareHarbor calendar of item #{itemId} -->
        <script is:inline src={calendarSrc}></script>
      </div>
    </div>
  </Container>
</section>
