---
import type { BookTourTranslations } from "./book-tour.i18n";
import type { Language } from "@/lib/i18n";
import Container from "@/components/ui/Container.astro";
import PageHero from "@/components/ui/PageHero.astro";
import { siteData } from "@/data/site";

interface Props {
  lang: Language;
  t: BookTourTranslations;
}

const { lang, t } = Astro.props;
const { shortname, flow } = siteData.coffeeTour.fareharbor;
const calendarSrc = `https://fareharbor.com/embeds/script/items/${shortname}/?fallback=simple&full-items=yes&flow=${flow}`;
---

<PageHero title={t.hero.title} subtitle={t.hero.subtitle} />

<!-- FareHarbor Calendar Widget -->
<section class="py-16 md:py-24 bg-background">
  <Container>
    <div class="max-w-md mx-auto">
      <!-- FareHarbor full booking widget (all items, flow #{flow}) -->
      <script is:inline src={calendarSrc}></script>
    </div>
  </Container>
</section>
