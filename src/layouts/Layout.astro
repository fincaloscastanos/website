---
import "@fontsource/raleway/300.css";
import "@fontsource/raleway/400.css";
import "@fontsource/raleway/600.css";
import "@fontsource/raleway/700.css";
import "@fontsource/oooh-baby/400.css";
import "@/styles/global.css";

import SeoHead from "@/components/SeoHead.astro";
import type { Language } from "@/lib/i18n";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import CookieConsent from "@/components/CookieConsent.astro";
import { siteData } from "@/data/site";

interface Props {
  title: string;
  description: string;
  lang: Language;
  routeKey: string;
  ogImage?: string;
  noindex?: boolean;
  fullBleed?: boolean;
  additionalSchemas?: Record<string, unknown>[];
}
const { title, description, lang, routeKey, ogImage, noindex, fullBleed, additionalSchemas } = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-pt-16 md:scroll-pt-20">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <SeoHead
      title={title}
      description={description}
      lang={lang}
      routeKey={routeKey}
      ogImage={ogImage}
      noindex={noindex}
      additionalSchemas={additionalSchemas}
    />
    {import.meta.env.PROD && (
      <script
        defer
        src="https://analytics.pulpo.cloud/script.js"
        data-website-id={siteData.analytics_id}></script>
    )}
  </head>
  <body
    class="min-h-screen flex flex-col bg-background text-text"
  >
    <Header lang={lang} routeKey={routeKey} fullBleed={fullBleed} />
    <main class:list={["flex-1", !fullBleed && "pt-16 md:pt-20"]}>
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieConsent lang={lang} />
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
