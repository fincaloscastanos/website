---
import { languages } from "@/lib/i18n";
import { getTranslatedPath } from "@/lib/registry";
import type { Language } from "@/lib/i18n";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Language;
  routeKey: string;
}
const { lang, routeKey } = Astro.props;

const flagIcons: Record<Language, string> = {
  es: "twemoji:flag-spain",
  de: "twemoji:flag-germany",
  en: "twemoji:flag-united-kingdom",
};
---

<div class="flex items-center gap-3">
  {
    languages.map((l) => {
      const isActive = l === lang;
      const href = getTranslatedPath(routeKey, l);

      return (
        <a
          href={href}
          hreflang={l}
          class:list={[
            "group relative flex flex-col items-center transition-all duration-300",
            isActive
              ? ""
              : "opacity-50 hover:opacity-100",
          ]}
          aria-label={`Switch to ${l}`}
        >
          <Icon
            name={flagIcons[l]}
            class:list={[
              "h-[18px] w-[27px] md:h-[22px] md:w-[33px] block rounded-[3px] transition-all duration-300",
              isActive
                ? "grayscale-0"
                : "grayscale group-hover:grayscale-0",
            ]}
          />
          <span
            class:list={[
              "mt-1 h-[2px] w-4 md:w-5 rounded-full transition-all duration-300",
              isActive
                ? "bg-secondary"
                : "bg-transparent group-hover:bg-secondary/40",
            ]}
          />
        </a>
      );
    })
  }
</div>
