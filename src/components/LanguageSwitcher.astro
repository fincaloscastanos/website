---
import { languages } from "@/lib/i18n";
import { getTranslatedPath } from "@/lib/registry";
import type { Language } from "@/lib/i18n";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Language;
  routeKey: string;
}
const { lang, routeKey } = Astro.props;

const flagIcons: Record<Language, string> = {
  es: "flag:es-4x3",
  de: "flag:de-4x3",
  en: "flag:gb-4x3",
};
---

<div class="flex items-center gap-3">
  {
    languages.map((l) => {
      const isActive = l === lang;
      const href = getTranslatedPath(routeKey, l);

      return (
        <a
          href={href}
          hreflang={l}
          class="group relative flex flex-col items-center transition-all duration-300"
          aria-label={`Switch to ${l}`}
        >
          <Icon
            name={flagIcons[l]}
            class:list={[
              "h-[20px] w-[30px] md:h-[24px] md:w-[36px] block transition-all duration-300 header-flag",
            ]}
          />
          <span
            class:list={[
              "mt-1 h-[2px] w-[30px] md:w-[36px] transition-all duration-300",
              isActive
                ? "bg-secondary"
                : "bg-transparent group-hover:bg-secondary/40",
            ]}
          />
        </a>
      );
    })
  }
</div>
