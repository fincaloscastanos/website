---
import { getImage } from "astro:assets";
import defaultOgImageSource from "../assets/og-default.png";

import {
  languages,
  defaultLang,
  type Language,
  openGraphLocales,
} from "@/lib/i18n";
import { getTranslatedPath } from "@/lib/registry";
import { getNavbarItems } from "@/lib/navbar";
import { siteData } from "@/data/site";

interface Props {
  title: string;
  description: string;
  lang: Language;
  routeKey: string;
  ogImage?: string | ImageMetadata;
  noindex?: boolean;
  additionalSchemas?: Record<string, unknown>[];
}

const {
  title,
  description,
  lang,
  routeKey,
  ogImage,
  noindex = false,
  additionalSchemas = [],
} = Astro.props;

const siteUrl =
  Astro.site?.toString().replace(/\/$/, "") || "http://localhost:4321";

const imageToOptimize = ogImage || defaultOgImageSource;
const optimizedImage = await getImage({
  src: imageToOptimize,
  format: "jpg",
  width: 1200,
  height: 630,
  quality: 90,
});

const image = new URL(optimizedImage.src, Astro.site).toString();

const canonicalURL = new URL(
  getTranslatedPath(routeKey, lang),
  siteUrl,
).toString();

const xDefaultHref = new URL(
  getTranslatedPath(routeKey, defaultLang),
  siteUrl,
).toString();
const currentLocale = openGraphLocales[lang];

const alternates = languages.map((l) => ({
  lang: l,
  href: new URL(getTranslatedPath(routeKey, l), siteUrl).toString(),
  locale: openGraphLocales[l],
}));

const robotsContent = noindex ? "noindex, nofollow" : "index, follow";

const navItems = await getNavbarItems(lang, Astro.url.pathname);

const homeLabel = lang === "de" ? "Startseite" : lang === "en" ? "Home" : "Inicio";
const homeUrl = new URL(getTranslatedPath("home", lang), siteUrl).toString();
const breadcrumbItems: { name: string; url: string }[] = [{ name: homeLabel, url: homeUrl }];
if (routeKey !== "home") {
  const currentNavItem = navItems.find((item) => item.isActive);
  breadcrumbItems.push({
    name: currentNavItem?.label || title,
    url: canonicalURL,
  });
}
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="robots" content={`${robotsContent}, max-snippet:-1, max-image-preview:large, max-video-preview:-1`} />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Hreflang Tags -->
<link rel="alternate" hreflang="x-default" href={xDefaultHref} />
{
  alternates.map((link) => (
    <link rel="alternate" hreflang={link.lang} href={link.href} />
  ))
}

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />
<meta property="og:site_name" content={siteData.meta.name} />

<!-- Open Graph Locales -->
<meta property="og:locale" content={currentLocale} />
{
  alternates
    .filter((link) => link.lang !== lang)
    .map((link) => (
      <meta property="og:locale:alternate" content={link.locale} />
    ))
}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />
{
  siteData.meta.twitterHandle && (
    <meta name="twitter:site" content={siteData.meta.twitterHandle} />
  )
}

<!-- Schema.org JSON-LD -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: siteData.meta.name,
        url: siteUrl,
        logo: {
          "@type": "ImageObject",
          url: new URL("/favicon.png", siteUrl).toString(),
        },
        contactPoint: {
          "@type": "ContactPoint",
          telephone: siteData.contact.phone,
          contactType: "customer service",
          availableLanguage: ["Spanish", "English", "German"],
        },
        sameAs: [siteData.social.instagram, siteData.social.facebook, "https://maps.app.goo.gl/oZts3DjDY23nveaQ9"],
      },
      {
        "@type": ["LocalBusiness", "TouristAttraction"],
        "@id": `${siteUrl}/#localbusiness`,
        name: siteData.meta.name,
        description: lang === "de"
          ? "Historische Kaffeeplantage im Valle de Agaete, Gran Canaria – Kaffeetouren, Ferienwohnungen und Events in Europas einziger Kaffeeanbauregion."
          : lang === "en"
          ? "Historic coffee plantation in the Valle de Agaete, Gran Canaria – coffee tours, holiday apartments and events in Europe's only coffee-growing region."
          : "Finca de café histórica en el Valle de Agaete, Gran Canaria – tours de café, apartamentos vacacionales y eventos en la única región cafetera de Europa.",
        url: siteUrl,
        image: image,
        telephone: siteData.contact.phone,
        email: siteData.contact.email,
        address: {
          "@type": "PostalAddress",
          streetAddress: "Camino de Los Romeros S/N",
          addressLocality: "Agaete",
          postalCode: "35489",
          addressRegion: "Las Palmas",
          addressCountry: "ES",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: 28.0810937,
          longitude: -15.6731384,
        },
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: "4.7",
          bestRating: "5",
          ratingCount: "384",
        },
        openingHoursSpecification: [
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            opens: siteData.hours.weekdays.start,
            closes: siteData.hours.weekdays.end,
          },
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: ["Saturday", "Sunday"],
            opens: siteData.hours.weekends.start,
            closes: siteData.hours.weekends.end,
          },
        ],
        priceRange: "€€",
        currenciesAccepted: "EUR",
        paymentAccepted: "Cash, Credit Card",
        isAccessibleForFree: false,
        publicAccess: true,
        touristType: ["Coffee Lovers", "Nature Enthusiasts", "Cultural Tourists"],
        availableLanguage: ["Spanish", "English", "German"],
        hasOfferCatalog: {
          "@type": "OfferCatalog",
          name: lang === "de" ? "Angebote" : lang === "en" ? "Services" : "Servicios",
          itemListElement: [
            {
              "@type": "OfferCatalog",
              name: lang === "de" ? "Kaffeetour" : lang === "en" ? "Coffee Tour" : "Tour de café",
              itemListElement: [
                {
                  "@type": "Offer",
                  itemOffered: {
                    "@type": "TouristTrip",
                    name: lang === "de" ? "Geführte Kaffeetour" : lang === "en" ? "Guided Coffee Tour" : "Tour de café guiado",
                    description: lang === "de"
                      ? "45-minütige Führung durch die Kaffeeplantage mit Verkostung"
                      : lang === "en"
                      ? "45-minute guided tour of the coffee plantation with tasting"
                      : "Visita guiada de 45 minutos por la plantación de café con degustación",
                    touristType: ["Coffee Lovers", "Cultural Tourists"],
                    itinerary: {
                      "@type": "ItemList",
                      itemListElement: [
                        { "@type": "ListItem", position: 1, name: lang === "de" ? "Plantagenrundgang" : lang === "en" ? "Plantation walk" : "Recorrido por la plantación" },
                        { "@type": "ListItem", position: 2, name: lang === "de" ? "Kaffeeverkostung" : lang === "en" ? "Coffee tasting" : "Degustación de café" },
                      ],
                    },
                  },
                  price: siteData.coffeeTour.adultsOnline,
                  priceCurrency: "EUR",
                  availability: "https://schema.org/InStock",
                  validFrom: "2025-01-01",
                },
              ],
            },
          ],
        },
      },
      {
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        url: siteUrl,
        name: siteData.meta.name,
        publisher: { "@id": `${siteUrl}/#organization` },
        inLanguage: ["es", "en", "de"],
      },
      {
        "@type": "WebPage",
        "@id": `${canonicalURL}#webpage`,
        url: canonicalURL,
        name: title,
        description: description,
        isPartOf: { "@id": `${siteUrl}/#website` },
        about: { "@id": `${siteUrl}/#localbusiness` },
        inLanguage: lang,
        datePublished: "2025-01-01",
        dateModified: new Date().toISOString().split("T")[0],
        breadcrumb: { "@id": `${canonicalURL}#breadcrumb` },
        speakable: {
          "@type": "SpeakableSpecification",
          cssSelector: ["h1", "[data-speakable]", "meta[name='description']"],
        },
      },
      {
        "@type": "BreadcrumbList",
        "@id": `${canonicalURL}#breadcrumb`,
        itemListElement: breadcrumbItems.map((item, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: item.name,
          item: item.url,
        })),
      },
      {
        "@type": "ItemList",
        "@id": `${siteUrl}/#navigation`,
        itemListElement: navItems.map((item, i) => ({
          "@type": "SiteNavigationElement",
          position: i + 1,
          name: item.label,
          url: new URL(item.href, siteUrl).toString(),
        })),
      },
      ...additionalSchemas,
    ],
  })}
/>
