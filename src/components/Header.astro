---
import Container from "@/components/ui/Container.astro";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import { getNavbarItems } from "@/lib/navbar";
import { getTranslatedPath } from "@/lib/registry";
import type { Language } from "@/lib/i18n";
import { Image } from "astro:assets";
import logoGray from "@/assets/logo-text-gray.png";
import logoWhite from "@/assets/logo-text-white.png";

interface Props {
  lang: Language;
  routeKey: string;
  fullBleed?: boolean;
}
const { lang, routeKey, fullBleed } = Astro.props;

const navItems = await getNavbarItems(lang, Astro.url.pathname);
const homeHref = getTranslatedPath("home", lang);
---

<header
  id="site-header"
  class="fixed top-(--announce-h,0px) left-0 z-50 w-full transition-all duration-300"
  {...fullBleed ? { "data-fullbleed": "" } : { "data-scrolled": "" }}
>
  <Container>
    <div class="flex h-16 md:h-20 items-center justify-between">
      <!-- Logo -->
      <a
        href={homeHref}
        class="relative z-50"
      >
        <Image
          src={logoWhite}
          alt="Finca Los Castaños"
          class="h-9 md:h-11 w-auto transition-opacity duration-300 header-logo-white"
          quality="max"
        />
        <Image
          src={logoGray}
          alt="Finca Los Castaños"
          class="h-9 md:h-11 w-auto absolute inset-0 transition-opacity duration-300 opacity-0 header-logo-gray"
          quality="max"
        />
      </a>

      <!-- Desktop Nav -->
      <nav
        class="hidden md:flex items-center gap-4 lg:gap-6 text-base font-medium header-nav"
      >
        {
          navItems.map((item) => {
            return (
              <a
                href={item.href}
                class:list={[
                  "transition-all duration-300 header-nav-link",
                  item.isActive && "font-bold active",
                ]}
              >
                {item.label}
              </a>
            );
          })
        }
      </nav>

      <!-- Desktop Language Switcher -->
      <div class="hidden md:flex items-center gap-4">
        <LanguageSwitcher lang={lang} routeKey={routeKey} />
      </div>

      <!-- Mobile Menu Toggle Button -->
      <button
        id="menu-toggle"
        aria-label="Toggle Menu"
        class="relative z-50 flex flex-col justify-center gap-1.5 p-2 md:hidden group"
      >
        <span
          class="h-0.5 w-5 md:w-6 transition-all duration-300 header-burger-line group-data-open:rotate-45 group-data-open:translate-y-2"
        ></span>
        <span
          class="h-0.5 w-5 md:w-6 transition-all duration-300 header-burger-line group-data-open:opacity-0"
        ></span>
        <span
          class="h-0.5 w-5 md:w-6 transition-all duration-300 header-burger-line group-data-open:-rotate-45 group-data-open:-translate-y-2"
        ></span>
      </button>
    </div>
  </Container>

  <!--
    Mobile Menu Overlay
  -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 flex flex-col items-center justify-start w-screen h-dvh bg-background transition-all duration-300 translate-x-full opacity-0 invisible md:hidden pt-24 sm:pt-28 overscroll-contain"
  >
    <!-- Nav Container: Erlaubt Scrollen im Menü, falls das Handy sehr klein ist -->
    <nav
      class="flex flex-col items-center gap-4 sm:gap-6 text-center w-full px-6 overflow-y-auto max-h-[70vh]"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-2xl sm:text-3xl font-serif transition-colors duration-300 mobile-link w-full py-3 sm:py-4 border-b border-border",
              item.isActive
                ? "text-secondary"
                : "text-text-muted hover:text-primary",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Language Switcher Mobile -->
    <div
      class="mt-8 sm:mt-10 scale-125 sm:scale-150"
    >
      <LanguageSwitcher lang={lang} routeKey={routeKey} />
    </div>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  const body = document.body;
  const html = document.documentElement;

  let isOpen = false;

  function toggleMenu() {
    isOpen = !isOpen;

    if (isOpen) {
      // --- ÖFFNEN ---
      menuToggle?.setAttribute("data-open", "");
      mobileMenu?.classList.remove("invisible");

      requestAnimationFrame(() => {
        mobileMenu?.classList.remove("translate-x-full", "opacity-0");
        mobileMenu?.classList.add("translate-x-0", "opacity-100");
      });

      // Hardcore Scroll Lock (Body & HTML)
      body.style.overflow = "hidden";
      html.style.overflow = "hidden";
    } else {
      // --- SCHLIEßEN ---
      menuToggle?.removeAttribute("data-open");

      mobileMenu?.classList.add("translate-x-full", "opacity-0");
      mobileMenu?.classList.remove("translate-x-0", "opacity-100");

      // Scroll Lock aufheben
      body.style.overflow = "";
      html.style.overflow = "";
    }
  }

  // Warten bis Animation fertig ist, dann invisible setzen
  mobileMenu?.addEventListener("transitionend", () => {
    if (!isOpen) {
      mobileMenu.classList.add("invisible");
    }
  });

  menuToggle?.addEventListener("click", toggleMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isOpen) toggleMenu();
    });
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768 && isOpen) {
      toggleMenu();
    }
  });

  // --- Scroll: transparent → solid (nur bei fullBleed) ---
  const header = document.getElementById("site-header");
  const isFullBleed = header?.hasAttribute("data-fullbleed");

  function updateHeader() {
    if (!header || !isFullBleed) return;
    if (window.scrollY > 50) {
      header.setAttribute("data-scrolled", "");
    } else {
      header.removeAttribute("data-scrolled");
    }
  }

  updateHeader();
  window.addEventListener("scroll", updateHeader, { passive: true });
</script>
