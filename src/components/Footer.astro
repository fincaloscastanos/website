---
import Container from "./ui/Container.astro";
import type { Language } from "@/lib/i18n";
import { siteData } from "@/data/site";
import { getTranslatedPath } from "@/lib/registry";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const currentYear = new Date().getFullYear();

const imprintLabel = { de: "Impressum", en: "Legal Notice", es: "Aviso legal" };
const termsLabel = { de: "AGB", en: "Terms & Conditions", es: "Condiciones generales" };
const privacyLabel = { de: "Datenschutz", en: "Privacy Policy", es: "Protección de datos" };
---

<footer class="border-t border-border/50 bg-surface mt-auto">
  <Container class="py-8">
    <div
      class="flex flex-col-reverse md:flex-row justify-between items-center gap-6"
    >
      <!-- Copyright -->
      <p class="text-sm text-text-muted text-center md:text-left">
        &copy; {currentYear}
        {siteData.meta.name}. All rights reserved.
      </p>

      <!-- Social -->
      <div class="flex items-center gap-4">
        <a
          href={`https://wa.me/${siteData.contact.whatsapp.replaceAll(" ", "").replace("+", "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-primary transition-colors"
          aria-label="WhatsApp"
        >
          <Icon name="simple-icons:whatsapp" class="w-5 h-5" />
        </a>
        <a
          href={siteData.social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-primary transition-colors"
          aria-label="Instagram"
        >
          <Icon name="simple-icons:instagram" class="w-5 h-5" />
        </a>
        <a
          href={siteData.social.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-primary transition-colors"
          aria-label="Facebook"
        >
          <Icon name="simple-icons:facebook" class="w-5 h-5" />
        </a>
      </div>

      <!-- Links -->
      <nav class="flex gap-6">
        <a
          href={getTranslatedPath("imprint", lang)}
          class="text-sm text-text-muted hover:text-primary transition-colors"
        >
          {imprintLabel[lang]}
        </a>
        <a
          href={getTranslatedPath("terms", lang)}
          class="text-sm text-text-muted hover:text-primary transition-colors"
        >
          {termsLabel[lang]}
        </a>
        <a
          href={getTranslatedPath("privacy", lang)}
          class="text-sm text-text-muted hover:text-primary transition-colors"
        >
          {privacyLabel[lang]}
        </a>
      </nav>
    </div>
  </Container>
</footer>
