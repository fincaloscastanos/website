---
interface Props {
  consentKey: string;
  activeValue?: string;
  inactiveValue?: string;
  revokeLabel: string;
  activateLabel: string;
  descriptionActive: string;
  descriptionInactive: string;
}

const { consentKey, activeValue = "true", inactiveValue, revokeLabel, activateLabel, descriptionActive, descriptionInactive } = Astro.props;
---

<div
  class="consent-revoke not-prose rounded-none border border-border bg-surface p-5 my-6"
  data-consent-key={consentKey}
  data-active-value={activeValue}
  data-inactive-value={inactiveValue}
>
  <p class="consent-revoke-desc text-sm text-text-muted mb-3"
    data-desc-active={descriptionActive}
    data-desc-inactive={descriptionInactive}
  ></p>
  <button
    class="consent-revoke-btn text-sm font-medium py-2 px-5 rounded-none transition-colors"
    data-revoke-label={revokeLabel}
    data-activate-label={activateLabel}
  >
  </button>
</div>

<script>
  const init = () => {
    document.querySelectorAll(".consent-revoke").forEach((wrapper) => {
      const btn = wrapper.querySelector(
        ".consent-revoke-btn",
      ) as HTMLButtonElement | null;
      const desc = wrapper.querySelector(
        ".consent-revoke-desc",
      ) as HTMLParagraphElement | null;
      if (!btn || !desc) return;

      const key = wrapper.getAttribute("data-consent-key");
      if (!key) return;

      const activeValue = wrapper.getAttribute("data-active-value") || "true";
      const inactiveValue = wrapper.getAttribute("data-inactive-value");

      const revokeLabel = btn.dataset.revokeLabel!;
      const activateLabel = btn.dataset.activateLabel!;
      const descActive = desc.dataset.descActive!;
      const descInactive = desc.dataset.descInactive!;

      const isActive = () => localStorage.getItem(key) === activeValue;

      const update = () => {
        const active = isActive();
        btn.textContent = active ? revokeLabel : activateLabel;
        desc.textContent = active ? descActive : descInactive;
        btn.classList.toggle("bg-secondary", active);
        btn.classList.toggle("text-secondary-foreground", active);
        btn.classList.toggle("hover:bg-secondary-dark", active);
        btn.classList.toggle("border", !active);
        btn.classList.toggle("border-primary", !active);
        btn.classList.toggle("text-primary", !active);
        btn.classList.toggle("hover:bg-primary/10", !active);
      };

      btn.addEventListener("click", () => {
        if (isActive()) {
          if (inactiveValue) {
            localStorage.setItem(key, inactiveValue);
          } else {
            localStorage.removeItem(key);
          }
        } else {
          localStorage.setItem(key, activeValue);
        }
        update();
      });

      update();
    });
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
