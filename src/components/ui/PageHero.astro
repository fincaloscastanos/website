---
import Container from "@/components/ui/Container.astro";

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="py-10 md:py-16 bg-surface">
  <Container>
    <div class="text-center max-w-3xl mx-auto">
      <h1
        class="text-xl md:text-2xl mb-2 font-sans uppercase tracking-wider font-bold"
      >
        {title}
      </h1>
      {
        subtitle && (
          <p class="font-serif text-primary text-2xl md:text-3xl mb-3">
            {subtitle}
          </p>
        )
      }
    </div>
  </Container>
</section>
