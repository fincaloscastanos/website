---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Container from "./Container.astro";

interface SubNavLink {
  href: string;
  label: string;
  image: ImageMetadata;
}

interface SubNavCta {
  href: string;
  label: string;
  external?: boolean;
}

interface Props {
  links?: SubNavLink[];
  cta?: SubNavCta;
}

const { links = [], cta } = Astro.props;
---

<section class="bg-background border-y border-primary/10">
  <Container>
    <div class="flex flex-col md:flex-row items-center justify-center gap-3 md:gap-8 py-4">
      <div class="flex flex-wrap items-center justify-center gap-4 md:gap-8">
        {links.map((link, i) => (
          <>
            {i > 0 && <div class="hidden md:block w-px h-6 bg-primary/15" />}
            <a href={link.href} class="group flex flex-col md:flex-row items-center gap-2 md:gap-3 px-5 py-3 md:py-2.5 rounded-none bg-surface md:bg-transparent border border-border/50 md:border-transparent hover:bg-surface hover:border-primary/20 transition-all duration-300">
              <div class="w-20 h-20 md:w-14 md:h-14 rounded-none overflow-hidden shrink-0 ring-2 ring-primary/20 group-hover:ring-primary transition-all duration-300">
                <Image
                  src={link.image}
                  alt={link.label}
                  class="w-full h-full object-cover"
                  widths={[112]}
                  sizes="56px"
                />
              </div>
              <span class="text-sm md:text-base font-medium text-text-heading group-hover:text-primary transition-colors duration-300 text-center md:text-left">{link.label}</span>
              <Icon name="lucide:arrow-right" class="w-4 h-4 text-primary transition-all duration-300 md:text-text-muted md:group-hover:text-primary md:group-hover:translate-x-0.5" />
            </a>
          </>
        ))}
      </div>

      {cta && (
        <a
          href={cta.href}
          target={cta.external ? "_blank" : undefined}
          rel={cta.external ? "noopener noreferrer" : undefined}
          class="inline-flex items-center gap-2 bg-secondary text-text-heading font-bold text-sm py-2.5 px-6 rounded-none hover:bg-secondary-dark transition-colors duration-300 shadow-sm"
        >
          {cta.label}
          <Icon name={cta.external ? "lucide:external-link" : "lucide:arrow-right"} class="w-3.5 h-3.5" />
        </a>
      )}
    </div>
  </Container>
</section>
