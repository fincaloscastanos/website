---
interface Props {
  consentKey: string;
  scripts?: string[];
  title: string;
  description: string;
  buttonLabel: string;
}

const {
  consentKey,
  scripts = [],
  title,
  description,
  buttonLabel,
} = Astro.props;
---

<div
  class="privacy-gate"
  data-consent-key={consentKey}
  data-scripts={JSON.stringify(scripts)}
>
  <!-- Consent placeholder -->
  <div
    class="privacy-gate-placeholder flex items-center justify-center p-8 bg-surface rounded-lg border border-border/50 min-h-[300px]"
  >
    <div class="text-center max-w-sm">
      <div
        class="w-12 h-12 bg-secondary/20 rounded-full flex items-center justify-center mx-auto mb-4 text-secondary"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
          ></path>
        </svg>
      </div>
      <h3 class="text-lg md:text-xl font-serif text-text-heading mb-2">
        {title}
      </h3>
      <p class="text-text-muted text-xs md:text-sm mb-5 leading-relaxed">
        {description}
      </p>
      <button
        class="privacy-gate-btn bg-secondary text-background font-bold py-2.5 px-6 rounded-full hover:bg-secondary/90 transition-all duration-300 shadow-lg text-xs md:text-sm uppercase tracking-wider"
      >
        {buttonLabel}
      </button>
    </div>
  </div>

  <!-- Gated content (hidden until consent) -->
  <div class="privacy-gate-content hidden">
    <slot />
  </div>
</div>

<script>
  const loadedScripts = new Set<string>();

  const loadScript = (src: string): Promise<void> => {
    if (loadedScripts.has(src)) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const script = document.createElement("script");
      script.src = src;
      script.onload = () => {
        loadedScripts.add(src);
        resolve();
      };
      script.onerror = reject;
      document.body.appendChild(script);
    });
  };

  const activateGate = async (gate: Element) => {
    const placeholder = gate.querySelector(
      ".privacy-gate-placeholder",
    ) as HTMLElement | null;
    const content = gate.querySelector(
      ".privacy-gate-content",
    ) as HTMLElement | null;
    if (!placeholder || !content) return;

    placeholder.style.display = "none";
    content.classList.remove("hidden");

    const scripts: string[] = JSON.parse(
      gate.getAttribute("data-scripts") || "[]",
    );
    for (const src of scripts) {
      await loadScript(src);
    }

    gate.dispatchEvent(
      new CustomEvent("privacy-gate:ready", { bubbles: true }),
    );
  };

  const init = () => {
    document.querySelectorAll(".privacy-gate").forEach((gate) => {
      const key = gate.getAttribute("data-consent-key");
      if (!key) return;

      if (localStorage.getItem(key) === "true") {
        activateGate(gate);
        return;
      }

      const btn = gate.querySelector(".privacy-gate-btn");
      if (btn) {
        btn.addEventListener(
          "click",
          () => {
            localStorage.setItem(key, "true");
            document
              .querySelectorAll(`.privacy-gate[data-consent-key="${key}"]`)
              .forEach((g) => activateGate(g));
          },
          { once: true },
        );
      }
    });
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
